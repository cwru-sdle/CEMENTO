        <mxCell id="OtxXyDLVaMyX7tXUTaGo-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;span style=&quot;text-align: left;&quot;&gt;Golf Drive Distance&lt;/span&gt;" vertex="1">
          <mxGeometry height="61" width="120" x="-480" y="41" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-11" edge="1" parent="1" source="OtxXyDLVaMyX7tXUTaGo-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="OtxXyDLVaMyX7tXUTaGo-13" value="owl:equivalentClass">
