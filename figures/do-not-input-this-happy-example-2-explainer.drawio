            <mxPoint x="-410" y="312" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Happy Gilmore Drive Distance" vertex="1">
          <mxGeometry height="61" width="120" x="-470" y="171" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-13" parent="1" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;" value="owl:intersectionOf" vertex="1">
          <mxGeometry height="120" width="140" x="-480" y="321" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-14" parent="OtxXyDLVaMyX7tXUTaGo-13" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;rounded=1;" value="Golf Drive Distance" vertex="1">
          <mxGeometry height="30" width="140" y="30" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-15" parent="OtxXyDLVaMyX7tXUTaGo-13" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;" value="owl:datatypeComplementOf" vertex="1">
          <mxGeometry height="60" width="140" y="60" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-16" parent="OtxXyDLVaMyX7tXUTaGo-15" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;rounded=1;" value="Amatuer Distance" vertex="1">
          <mxGeometry height="30" width="140" y="30" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=24;dashed=1;strokeWidth=5;" value="&lt;b&gt;DANGER&lt;/b&gt;: Do not use this file for input. Use the designated files for testing the package. That has the same terms and relationships without the guide text." vertex="1">
          <mxGeometry height="110" width="880" x="790" y="-1210" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-20" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Domains and Ranges&lt;/h1&gt;&lt;p&gt;You can declare domains and ranges using the original RFDS object properties.&lt;/p&gt;&lt;p&gt;Nested collections are now natively supported to allow for complex domain-range constructs.&lt;/p&gt;" vertex="1">
          <mxGeometry height="135" width="455" x="-425" y="-1025" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-21" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="You can use draw.io lists to create complex nested collections used in OWL turtle syntax." vertex="1">
          <mxGeometry height="90" width="150" x="-100" y="-570" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-22" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Equivalence and Disjointness&lt;/h1&gt;&lt;p&gt;Relationships between classes and instances now include declaration of equivalence and disjointness.&lt;/p&gt;&lt;p&gt;These statements are usually added for aligning ontologies, or creating complex statements about the nature of a class or object.&lt;/p&gt;" vertex="1">
          <mxGeometry height="170" width="430" x="420" y="-970" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-23" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The classes used on the left are declared here with their hierarchies for context." vertex="1">
          <mxGeometry height="110" width="150" x="1710" y="-910" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-24" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Properties can also have hierarchies albeit at more limited logical expressiveness." vertex="1">
          <mxGeometry height="110" width="150" x="2380" y="-800" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-26" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Datatypes and Data type ranges&lt;/h1&gt;&lt;p&gt;Datatypes are now officially supported alongside their with and inside in nested collections. Datatypes can also be used in domain and range definitions for datatype properties.&lt;/p&gt;" vertex="1">
          <mxGeometry height="100" width="530" x="-602.5" y="-250" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-27" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Literals can also be used in collections for things like datatype enumerations." vertex="1">
          <mxGeometry height="80" width="100" x="-270" y="210" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="As mentioned, datatypes can also be placed inside nested collections." vertex="1">
          <mxGeometry height="80" width="100" x="-600" y="350" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-29" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="XSD datatypes are supported, including turtle-based input formats for complicated types like duration." vertex="1">
          <mxGeometry height="81" width="150" x="390" y="299" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-30" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Property Restrictions&lt;/h1&gt;&lt;div&gt;The package supports all axioms and restrictions that can be described in the Manchester syntax (MS), except for deep restriction nesting, language ranges and the NOT construct. The package features a hybrid visual-first translation of MS concepts like restrictions, logical operations, property chain axioms and datatype facets.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="570" x="740" y="-220" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-31" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Enumerations&lt;/h1&gt;&lt;p&gt;Classes can now be defined in terms of enumerations, or lists of things that strictly compose a given class, object or concept. They use the list object from draw.io like other nested collections.&lt;/p&gt;" vertex="1">
          <mxGeometry height="100" width="600" x="-580" y="520" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-32" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="In this case, &lt;b&gt;Golf Tour Champion&lt;/b&gt;&amp;nbsp;can only have the listed player instances as members." vertex="1">
          <mxGeometry height="100" width="120" x="360" y="910" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-33" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Unlike windows and frames in MS, a restriction is a head node for the axiom/restriction statement. All restrictions start with &lt;b&gt;owl:Restriction&lt;/b&gt; header. Basic concepts like domains, ranges, and class equivalence don&#39;t need &lt;b&gt;owl:Restriction&lt;/b&gt;" vertex="1">
          <mxGeometry height="140" width="190" x="1000" y="88" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-34" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The hybrid syntax comes from using turtle terms to define the syntactic declaration of restrictions; for instance, &lt;b&gt;onProperty&lt;/b&gt; to refer to the property restrictions on a class." vertex="1">
          <mxGeometry height="110" width="190" x="655" y="310" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-35" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="CEMENTO defines shorthand notation for MS terms. The package comes with an ontology file that contains all translated concepts from turtle to MS." vertex="1">
          <mxGeometry height="110" width="190" x="580" y="521" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-36" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="A user is also able to define datatype facets. Instead of complicated nested turtle, datatypes can now be defined with the logically consistent MS bracket notation." vertex="1">
          <mxGeometry height="110" width="190" x="1730" y="575" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-37" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="A user can utilize nested collections inside restrictions, enabling the composition of several elements of logic into one cohesive diagram." vertex="1">
          <mxGeometry height="110" width="120" x="1070" y="640" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-38" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Each restriction is treated like a logic stream, in which one branch is a complete statement about that particular restriction." vertex="1">
          <mxGeometry height="90" width="170" x="1060" y="445.5" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-39" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Restriction branches always come from the same restriction head node. Branches that share a node are logically combined with the AND operator (i.e. owl:intersectionOf)" vertex="1">
          <mxGeometry height="90" width="230" x="940" y="260" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-40" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="This translates to the MS statement:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Types: hasWife min 1 HappyPerson&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="192.5" x="1213.75" y="810" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-42" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The term &lt;b&gt;ms:of&lt;/b&gt;&amp;nbsp;is used when chaining literals to classes." vertex="1">
          <mxGeometry height="40" width="130" x="1330" y="680" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-44" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Subproperty Chains&lt;/h1&gt;&lt;div&gt;Some classes might be defined by the behavior of their instances. RDF has the subproperty chain concept for this use case, and CEMENTO allows users to draw-up these restrictions with ease.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="260" x="1810" y="-265" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-45" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="The package uses a custom &lt;b&gt;ms:subPropertyChain&lt;/b&gt; term for declaring property chains." vertex="1">
          <mxGeometry height="90" width="230" x="2020" y="219" as="geometry" />
        </mxCell>
        <mxCell id="OtxXyDLVaMyX7tXUTaGo-46" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="The &lt;b&gt;ms:o&lt;/b&gt;&amp;nbsp;is used to chain one property to another in a property chain." vertex="1">
          <mxGeometry height="90" width="140" x="2020" y="361" as="geometry" />
