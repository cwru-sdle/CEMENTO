mds:LaserBeam a owl:Class ;
    rdfs:label "LaserBeam"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000011 ;
    skos:altLabel " " ;
    skos:definition "Laser Beam represents the spatially resolved normalised power density distribution of laser radiation along the beam direction. The normalisation implies that the integral over the power density distribution in any plane perpendicular to the beam axis yields to 1W. The power density distribution effective in the process zone then results as the product of the normalised power density distribution with th set laser power."@en ;
    skos:exactMatch lpbfo:LPBFO_00735 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-LPBF" .

mds:LaserFocusShift a owl:Class ;
    rdfs:label "LaserFocusShift"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "That is the offset of the beam focus relative to the process plane. Depending on the material and process regime, it is preferable to position the focus above or below the process plane."@en ;
    skos:exactMatch lpbfo:LPBFO_00742 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

