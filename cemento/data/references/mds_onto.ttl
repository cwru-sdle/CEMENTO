mds:PhotovoltaicModule a owl:Class ;
    rdfs:label "PhotovoltaicModule" ;
    rdfs:subClassOf mds:Sample ;
    skos:altLabel "Module", "module", 
        "PV Module",
        "Photovoltaic Module",
        "Solar Panel" ;
    skos:definition "A photovoltaic module is a collection of solar cell circuits sealed in an environmentally protective laminate. Packaging of modules typically includes layering cells between materials such as glass for the front and back, a top and rear encapsulation layer, cells and interconnects, passivation layers and optical coatings, all enclosed in a metal frame. Performance of PV modules are generally rated according to their electrical outputs under standard test conditions. Modules are used in the field together as arrays that make up a power generation site. " ;
    mds:hasDomain "BuiltEnv" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "PV-Module" .

