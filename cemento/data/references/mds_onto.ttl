    rdfs:label "LaserIntensity"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "Spatially resolved laser beam characterization in plane."@en ;
    skos:exactMatch lpbfo:LPBFO_00741 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

mds:LaserMode a owl:Class ;
    rdfs:label "LaserMode"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel " " ;
    skos:definition "Laser mode used for AM wehere the distribution of the phase position of the waves perpendicular to the direction of propagation is called transverse modes. E.g. With a cylindrical cross-section of the laser, the beam intensity ideally has a Gaussian profile; this mode is known as TEM00 mode."@en ;
    skos:exactMatch lpbfo:LPBFO_00024 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

