mds:ActOfPowderBedFusion a owl:Class ;
    rdfs:label "ActOfPowderBedFusion" ;
    dcterms:source "ISO/ASTM DIS 52900:2018(E)" ;
    rdfs:comment "This term is reused from https://github.com/ThomasBjarsch/ODE_AM/blob/main/PBFAO.ttl"@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( <https://w3id.org/ODE_AM/AMAO#ActOfAdditiveManufacturing> [ a owl:Restriction ;
                        owl:onProperty <http://www.ontologyrepository.com/CommonCoreOntologies/has_input> ;
                        owl:someValuesFrom <https://w3id.org/ODE_AM/MAO/PortionOfPowder> ] ) ] ;
    skos:altLabel "Selective laser melting"@en ;
    skos:definition "Additive manufacturing process in which thermal energy selectively fuses regions of a powder bed" ;
    skos:exactMatch pbfa:ActOfPowderBedFusion ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Material-LPBF" .

mds:ActOfPowderBedFusionLaserBeamMetal a owl:Class ;
    rdfs:label "ActOfPowderBedFusionLaserBeamMetal" ;
    rdfs:comment "This term is reused from https://github.com/ThomasBjarsch/ODE_AM/blob/main/PBFAO.ttl"@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( pbfa:ActOfPowderBedFusion [ a owl:Restriction ;
                        owl:onProperty <http://www.ontologyrepository.com/CommonCoreOntologies/has_output> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( <http://www.ontologyrepository.com/CommonCoreOntologies/Artifact> [ a owl:Restriction ;
                                            owl:onProperty <http://www.ontologyrepository.com/CommonCoreOntologies/is_made_of> ;
                                            owl:someValuesFrom <https://w3id.org/ODE_AM/MAO/PortionOfSteelMaterial> ] ) ] ] ) ] ;
    skos:altLabel " " ;
    skos:definition "ISO/ASTM DIS 52900:2018(E)",
        "The process category is powder bed fusion , using a laser beam (-LB), in a metallic material (/M)" ;
    skos:exactMatch pbfa:ActOfPowderBedFusionLaserBeamMetal ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Material-LPBF" .

