    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Rxn"@en .

mds:ReactionVessel a owl:Class ;
    rdfs:label "ReactionVessel" ;
    rdfs:subClassOf cco:ont00000020 ;
    skos:altLabel " " ;
    skos:definition "A vessel is a container in which a chemical reaction occurs."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Chem-Rxn"@en .

cco:ont00000327 a owl:Class ;
    rdfs:label "Texture"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A Quality that inheres in a bearer in virtue of the size, shape, and distribution of features on its surface, typically on a continuum from smooth to rough."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000441 a owl:Class ;
    rdfs:label "Temperature"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A Quality that inheres in a bearer in virtue of its thermal energy"@en,
        "A Quality that inheres in a bearer in virtue of its thermal energy."@en ;
    mds:hasDomain "Charact",
        "Chem"@en ;
    mds:hasStudyStage "Materials Processing",
        "Recipe",
        "Result",
        "Sample",
        "Synthesis" ;
