    skos:definition "An Artifact Function that is realized during events in which an Artifact is used to perform a process involving electrical power."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000138 a owl:Class ;
    rdfs:label "Maximum Power"@en ;
    rdfs:subClassOf cco:ont00000503 ;
    skos:definition "A Power that is characterized by the maximum rate of Work, or Energy consumed, done in a given time period."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Result" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000170 a owl:Class ;
    rdfs:label "Object Track Point"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001944 ;
            owl:someValuesFrom cco:ont00000205 ],
        obo:BFO_0000018 ;
    skos:definition "A Zero-Dimensional Spatial Region that is an idealized point where an Object is or was located during some motion."@en ;
    mds:hasDomain "Charact" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/GeospatialOntology"^^xsd:anyURI .

cco:ont00000267 a owl:Class ;
    rdfs:label "Catalyst Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000791 ;
    skos:definition "A Chemical Reaction Artifact Function that is realized in a process in which the rate of a chemical reaction is increased due to the participation of an additional substance, without that substance being consumed in the reaction."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation",
        "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Catalysis&oldid=1063864001"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000413 a owl:Class ;
    rdfs:label "Electron Microscope"@en ;
    rdfs:subClassOf cco:ont00000304 ;
    skos:definition "A Microscope that is designed to use a beam of accelerated electrons to illuminate the target and produce a significantly enlarged image of the Object."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Electron_microscope&oldid=1060512240"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000419 a owl:Class ;
    rdfs:label "Part Number"@en ;
    rdfs:subClassOf cco:ont00000077 ;
    skos:altLabel "Sample Number" ;
    skos:definition "A Code Identifier that designates a type of part whose instances are designed to be part of some Artifact."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

cco:ont00000436 a owl:Class ;
    rdfs:label "X-ray Microscope"@en ;
    rdfs:subClassOf cco:ont00000304 ;
    skos:definition "A Microscope that is designed to use Electromagnetic Radiation in the soft X-ray band to produce a significantly enlarged image of the Object."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=X-ray_microscope&oldid=1046169107"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000490 a owl:Class ;
    rdfs:label "X-ray Frequency"@en ;
    rdfs:subClassOf cco:ont00000754 ;
    skos:definition "An Electromagnetic Radiation Frequency of some Electromagnetic Wave that is between 30 petahertz and 30 exahertz."@en ;
    mds:hasStudyStage "Recipe" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000511 a owl:Class ;
    rdfs:label "Act of Planning"@en ;
    rdfs:subClassOf cco:ont00000228 ;
    skos:definition "A Planned Act that involves making a Plan to achieve some specified Objective."@en ;
    mds:hasStudyStage "Recipe" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000513 a owl:Class ;
    rdfs:label "Act of Tool Use"@en ;
    rdfs:subClassOf cco:ont00000566 ;
    skos:definition "An Act of Artifact Employment in which some Agent uses some Tool."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000541 a owl:Class ;
    rdfs:label "Diameter"@en ;
    rdfs:subClassOf cco:ont00001367 ;
    skos:definition "A One Dimensional Extent that inheres in a circle in virtue of the extent of a straight line that passes through the center of the circle and starts and ends on the circle's boundary."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001754 "International Organization for Standardization. 2019. Quantities and units -- Part 3: Space and time (ISO 80000-3:2019). International Organization for Standardization. Available at: https://www.iso.org/standard/64974.html."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000614 a owl:Class ;
    rdfs:label "Mass"@en ;
    rdfs:comment "'Matter' here can also refer to the inertial energy of an object."@en,
        "Typical unit of measure is the kilogram or pound."@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A Quality that inheres in a bearer in virtue of the amount of matter in that bearer."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000633 a owl:Class ;
    rdfs:label "Weight"@en ;
    rdfs:comment "When an object is \"weighed\", in the typical case, it is done so by taking into account the local force of gravity to determine the object's mass, whose standard of measure is the kilogram. The actual unit of measure of weight is the newton."@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A Quality that inheres in some material entity with a mass in virtue of its location in some gravitational field."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000660 a owl:Class ;
    rdfs:label "Effect"@en ;
    rdfs:subClassOf obo:BFO_0000015 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( obo:BFO_0000015 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001819 ;
                        owl:someValuesFrom obo:BFO_0000015 ] ) ] ;
    skos:altLabel "Consequence"@en ;
    skos:definition "A Process that follows and is caused by some previous Process."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "http://wordnetweb.princeton.edu/perl/webwn?s=effect" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000712 a owl:Class ;
    rdfs:label "Acceleration"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001777 ;
            owl:someValuesFrom cco:ont00000763 ],
        obo:BFO_0000144 ;
    skos:definition "A Process Profile that is the rate of change of the Velocity of an object."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Acceleration&oldid=1062249960"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000806 a owl:Class ;
    rdfs:label "Power Tool"@en ;
    rdfs:subClassOf cco:ont00000581 ;
    skos:definition "A Tool that is designed to be actuated by a Power Source and mechanism other than or in addition to manual labor."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Power_tool&oldid=1057147715"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000808 a owl:Class ;
    rdfs:label "Reactant Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000791 ;
    skos:definition "A Chemical Reaction Artifact Function that is realized in a process in which a substance or compound is added to a system in order to bring about a chemical reaction and is consumed in the course of the reaction."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Reagent&oldid=1017651471"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000843 a owl:Class ;
    rdfs:label "Solar Panel"@en ;
    rdfs:subClassOf cco:ont00001049 ;
    skos:definition "An Electrical Power Source that consists in part of one or more photovoltaic (i.e. solar) cells that convert light energy (photons) directly into electricity by means of the photovoltaic effect."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Solar_cell&oldid=1063439932"^^xsd:anyURI,
        "https://en.wikipedia.org/w/index.php?title=Solar_panel&oldid=1064397496"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000849 a owl:Class ;
    rdfs:label "Heating System"@en ;
    rdfs:subClassOf cco:ont00000453 ;
    skos:definition "An Environment Control System that is designed to heat the air or objects in a Site."@en ;
    mds:hasStudyStage "Materials Processing",
        "Synthesis",
        "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000856 a owl:Class ;
    rdfs:label "Artifact History"@en ;
    rdfs:subClassOf obo:BFO_0000182 ;
    skos:definition "A History of an Artifact."@en ;
    mds:hasStudyStage "Recipe" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000893 a owl:Class ;
    rdfs:label "Information Medium Artifact"@en ;
    rdfs:comment "An empty notebook, when manufactured, is a medium but not yet a carrier of information content. However, a book, in the sense of a novel or collection of philosophical essays or poems, depends necessarily on it carrying some information content. Thus, there are no empty books. Likewise, there are no empty databases, only portions of digital storage that have not yet been configured to carry some information content according to a database software application."@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to have some Information Bearing Artifact as part."@en ;
    skos:example "A magnetic hard drive",
        "A notebook" ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000910 a owl:Class ;
    rdfs:label "Amplitude"@en ;
    rdfs:subClassOf obo:BFO_0000144 ;
    skos:definition "A Process Profile of an Oscillation Process that is the absolute value of the maximum displacement from a zero, equilibrium, or mean value during one cycle of the Oscillation Process."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000944 a owl:Class ;
    rdfs:label "Thermal Imaging Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000601 ;
    skos:definition "An Imaging Artifact Function that is realized during events in which an Artifact is used to create a visual representation of an entity using radiation from the far infrared region of the electromagnetic spectrum that the entity emits"@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000945 a owl:Class ;
    rdfs:label "X-ray Telescope"@en ;
    rdfs:subClassOf cco:ont00000547 ;
    skos:definition "A Telescope that is designed to aid in the observation of spatially distant Objects by means of collecting and focusing X-rays to form an enhanced image of the Object."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=X-ray_telescope&oldid=1035025593"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000947 a owl:Class ;
    rdfs:label "Temperature Measurement Artifact Function"@en ;
    rdfs:subClassOf cco:ont00001100 ;
    skos:definition "A Measurement Artifact Function that is realized during events in which an Artifact is used to measure the Temperature of a specified object or class of objects."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000950 a owl:Class ;
    rdfs:label "Act of Maintenance"@en ;
    rdfs:subClassOf cco:ont00000970 ;
    skos:definition "An Act of Artifact Modification in which an Artifact is modified in order to preserve or restore one or more of its designed Qualities or Functions."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000978 a owl:Class ;
    rdfs:label "Cause"@en ;
    rdfs:subClassOf obo:BFO_0000015 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( obo:BFO_0000015 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001803 ;
                        owl:someValuesFrom obo:BFO_0000015 ] ) ] ;
    skos:definition "A Process that is the cause of or one of the causes of some other Process."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000981 a owl:Class ;
    rdfs:label "Act of Portion of Material Consumption"@en ;
    rdfs:subClassOf cco:ont00000566 ;
    skos:definition "An Act of Artifact Employment in which a Portion of Material is expended."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001013 a owl:Class ;
    rdfs:label "Heating Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000323 ;
    skos:definition "An Artifact Function that is realized in a process in which the thermal energy of a system increases."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001056 a owl:Class ;
    rdfs:label "Visible Light Frequency"@en ;
    rdfs:comment "Visible light overlaps with near infrared and near ultraviolet" ;
    rdfs:subClassOf cco:ont00000754 ;
    skos:definition "An Electromagnetic Radiation Frequency of some Electromagnetic Wave that is between 400 and 800 terahertz"@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Opt-UvVis" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Light&oldid=1062630851"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001067 a owl:Class ;
    rdfs:label "Laser"@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to emit light coherently through a process of optical amplification based on the stimulated emission of electromagnetic radiation."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Laser&oldid=1059215159"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001153 a owl:Class ;
    rdfs:label "Damaging Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000323 ;
    skos:definition "An Artifact Function that is realized in a process in which the structural integrity of an entity is impaired."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001160 a owl:Class ;
    rdfs:label "Solvent Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000791 ;
    skos:definition "A Chemical Reaction Artifact Function that is realized in the dissolving of other substances (namely, solutes) without change in the former's chemical structure."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Solvent&oldid=1062572314"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001207 a owl:Class ;
    rdfs:label "Optical Lens"@en ;
    rdfs:subClassOf cco:ont00000136 ;
    skos:altLabel "Lens"@en ;
    skos:definition "An Optical Instrument that is designed to focus or disperse a beam of light entering the lens by means of refraction."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Lens_(optics)" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001218 a owl:Class ;
    rdfs:label "Signal Processing Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000323 ;
    skos:definition "An Artifact Function that is realized in the process of transferring or processing information contained in signals."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Signal_processing&oldid=1062720685"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001222 a owl:Class ;
    rdfs:label "Solar Panel System"@en ;
    rdfs:subClassOf cco:ont00001049 ;
    skos:altLabel "Photovoltaic System"@en,
        "Solar Array"@en ;
    skos:definition "An Electrical Power Source that consists in part of one or more Solar Panels, a power inverter, electrical wiring between the components, a mounting and support structure, and may also include a battery and/or a solar tracking system and is the bearer of functions realized in processes of deriving, transferring, and storing electrical energy derived from light energy."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Photovoltaic_system&oldid=1063366598"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001242 a owl:Class ;
    rdfs:label "Actuator"@en ;
    rdfs:subClassOf cco:ont00000736 ;
    skos:definition "A Transducer that is designed to convert some control signal into mechanical motion."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Actuator&oldid=1064000375"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001294 a owl:Class ;
    rdfs:label "Three Dimensional Extent"@en ;
    rdfs:subClassOf cco:ont00001202 ;
    skos:altLabel "Volume"@en ;
    skos:definition "A Size Quality that inheres in a bearer in virtue of the bearer's extension in three dimensions."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "International Organization for Standardization. 2019. Quantities and units -- Part 3: Space and time (ISO 80000-3:2019). International Organization for Standardization. Available at: https://www.iso.org/standard/64974.html."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00001332 a owl:Class ;
    rdfs:label "Ultraviolet Light Frequency"@en ;
    rdfs:subClassOf cco:ont00000610 ;
    skos:definition "An Electromagnetic Radiation Frequency of some Electromagnetic Wave that is between 750 terahertz and 30 petahertz"@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Opt-UvVis" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Ultraviolet&oldid=1062593453"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001337 a owl:Class ;
    rdfs:label "Infrared Light Frequency"@en ;
    rdfs:subClassOf cco:ont00000754 ;
    skos:definition "An Electromagnetic Radiation Frequency of some Electromagnetic Wave that is between 300 gigahertz and 430 tetrahertz."@en ;
    mds:hasStudyStage "Recipe" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Infrared&oldid=1064111319"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001360 a owl:Class ;
    rdfs:label "Three Dimensional Shape"@en ;
    rdfs:subClassOf cco:ont00001059 ;
    skos:definition "A Shape Quality that inheres only in a three dimensional entity."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00001376 a owl:Class ;
    rdfs:label "Torque"@en ;
    rdfs:subClassOf cco:ont00000570 ;
    skos:altLabel "Moment of Force"@en ;
    skos:definition "A Force that is applied to an object in a direction that would tend to cause the object to rotate around an Axis of Rotation and is the rate of change of an object's Angular Momentum."@en ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Torque&oldid=1063339484"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001384 a owl:Class ;
    rdfs:label "Opacity"@en ;
    rdfs:subClassOf cco:ont00000628 ;
    skos:definition "An Electromagnetic Radiation Property that inheres in a bearer in virtue of that bearer's capacity to transmit electromagnetic radiation of a given frequency through the bearer instead of reflecting, scattering, or absorbing electromangentic radiation of that frequency."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Opacity_(optics)" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00001754 a owl:AnnotationProperty ;
    rdfs:label "definition source"@en ;
    skos:definition "A citation of where all or some of the information used to create the term's Definition was acquired from."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001760 a owl:AnnotationProperty ;
    rdfs:label "is curated in ontology"@en ;
    skos:definition "An annotation property that links a class, property, or named individual to the URI of the ontology where it is located."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001808 a owl:ObjectProperty ;
    rdfs:label "is about"@en ;
    owl:inverseOf cco:ont00001801 .

cco:ont00001816 a owl:ObjectProperty ;
    rdfs:label "is output of"@en ;
    rdfs:domain obo:BFO_0000002 ;
    rdfs:range obo:BFO_0000015 ;
    rdfs:subPropertyOf obo:BFO_0000056 ;
    owl:inverseOf cco:ont00001986 ;
    skos:definition "x is_output_of y iff x is an instance of Continuant and y is an instance of Process, such that the presence of x at the end of y is a necessary condition for the completion of y."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .


cco:ont00001778 rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf obo:BFO_0000057 ;
                 owl:inverseOf cco:ont00001936 ;
                 rdfs:label "has object"@en ;
                 skos:definition "If p is a process and c is a continuant, then p has object c if and only if p is performed by an agent and c is part of the projected state that agent intends to achieve by performing p."@en ;
                 cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001845 a owl:ObjectProperty ;
    rdfs:label "is site of"@en ;
    rdfs:domain obo:BFO_0000029 ;
    rdfs:range obo:BFO_0000015 ;
    rdfs:subPropertyOf obo:BFO_0000183 ;
    owl:inverseOf cco:ont00001918 ;
    skos:definition "x is_site_of y iff x is an instance of Site and y is an instance of Process, such that y occurs in x."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001938 a owl:ObjectProperty ;
    rdfs:label "represents"@en .

cco:ont00001966 a owl:ObjectProperty ;
    rdfs:label "is a measurement of"@en ;
    owl:inverseOf cco:ont00001904 .

cco:ont00001982 a owl:ObjectProperty ;
    rdfs:label "describes"@en ;
    owl:inverseOf cco:ont00001917 .

afe:AFE_0000052 a owl:Class ;
    rdfs:label "cuvette" ;
    rdfs:comment "This term is reused from Allotrope Foundation Equipment Ontology."@en ;
    rdfs:subClassOf mds:Accessory ;
    skos:definition "A cuvette is a small tube of circular or square cross section, sealed at least at one end, made of plastic, glass, or fused quartz (for UV light) and designed to hold liquid samples for spectroscopic experiments" ;
    skos:exactMatch afe:AFE_0000052 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Opt-UvVis" .

afe:AFE_0000409 a owl:Class ;
    rdfs:label "monochromator" ;
    rdfs:comment "This term is reused from Allotrope Foundation Equipment Ontology"@en ;
    rdfs:subClassOf mds:Accessory ;
    skos:definition "A piece of apparatus that transmits a narrow band of wavelengths of light or other radiation (e.g. X-rays) chosen from a wider range of wavelengths availablear the inpupt" ;
    skos:exactMatch afe:AFE_0000409 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Opt-UvVis" .

afe:AFE_0001691 a owl:Class ;
    rdfs:label "non-contact probe"@en ;
    rdfs:comment "This term is reused from Allotrope Foundation Equipment Ontology."@en ;
    rdfs:subClassOf cco:onto00000581 ;
    skos:definition "A non-contact probe allows for measurements of a sample without touching it. [Allotrope]"@en ;
    skos:exactMatch afe:AFE_0001691 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-Profil" .

afe:AFE_0001772 a owl:Class ;
    rdfs:label "deuterium lamp",
        "deuterium lamp"@en ;
    rdfs:comment "This term is reused from Allotrope Foundation Equipment Ontology"@en ;
    rdfs:subClassOf cco:ont00000581 ;
    skos:definition "A deuterium lamp is a low-pressure gas-discharge light source that emits light with a continuous spectrum mainly in the ultraviolet region" ;
    skos:exactMatch afe:AFE_0001772 ;
    mds:hasDomain "Charact",
        "Chem"@en ;
    mds:hasSubDomain "Opt-UvVis",
        "Chem-Rxn"@en .

afe:AFE_0002248 a owl:Class ;
    rdfs:label "probe"@en ;
    rdfs:comment "This term is reused from Allotrope Foundation Equipment Ontology."@en ;
    rdfs:subClassOf cco:ont00000581 ;
    skos:definition "A probe is a device designed to reach into a location for remote manipulating or sensing. [NCI]"@en ;
    skos:exactMatch afe:AFE_0002248 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-Profil" .

afm:AFM_0000884 a owl:Class ;
