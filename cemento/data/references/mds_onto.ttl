    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( mds:CompositeMaterial [ a owl:Class ;
                        owl:unionOf ( [ a owl:Restriction ;
                                    owl:onProperty mds:hasReinforcement ;
                                    owl:someValuesFrom mds:CeramicMaterial ] [ a owl:Restriction ;
                                    owl:onProperty mds:hasReinforcement ;
                                    owl:someValuesFrom mds:MetallicMaterial ] ) ] [ a owl:Restriction ;
                        owl:onProperty mds:hasMatrix ;
                        owl:someValuesFrom mds:PolymericMaterial ] ) ] ;
