mds:EvacuateBackfill a owl:Class ;
    rdfs:label "EvacuateBackfill" ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel " " ;
    skos:definition "Evacuate-backfill is a process where a piece of vessel is prepared for a reaction by evacuate the ambient air and refill with inert gas. This is commonly done in reactions where presence of moisture and oxygen in the vessel during the reaction will negatively impact the outcome (i.e. lower yield, degradation of reagents, etc.)."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

