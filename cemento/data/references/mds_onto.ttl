    rdfs:comment "At every joint in any given electrical circuit, there is some form of connector present at the joint" ;
    rdfs:subClassOf cco:ont00000663 ;
    skos:altLabel "Electrical Port, Electrical Interface" ;
    skos:definition "A power transmission artifact that provides an interface for another power transmission artifact (ex. an electrical wire)." ;
    skos:example "USB port on a laptop, RJ45 (ethernet) port from the wall (not the respective wires)" ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain " " .

mds:PolymericMaterial a owl:Class ;
    rdfs:label "PolymericMaterial" ;
    rdfs:subClassOf mds:Material ;
    skos:altLabel " " ;
    skos:definition "A material that consists of very large molecules, or macromolecules, that are constituted by many repeating subunits derived from one or more species of monomers." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Formulation",
        "Sample" ;
    mds:hasSubDomain " " .

afe:AFE_0000718 a owl:Class ;
    rdfs:label "Tube"@en ;
    rdfs:subClassOf mds:ReactionVessel ;
