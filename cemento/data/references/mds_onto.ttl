mds:ScanStrategy a owl:Class ;
    rdfs:label "ScanStrategy"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "The scan strategy is a set of rules according to which the areas bounded by the cut lines per layer are filled with hatch and contour vectors. The set of rules also concerns the order an direction of the vectors, in particular an antiparallel alignment to the protective gas flow. The rules also specify the overlap between the exposure areas and a possible offset of the contour paths to the cut lines."@en ;
    skos:exactMatch lpbfo:LPBFO_00711 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Material-LPBF" .

mds:ScanVectorsPerLayer a owl:Class ;
    rdfs:label "ScanVectorsPerLayer"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "All scan vectors (hatch, contour) per layer and their Order."@en ;
    skos:exactMatch lpbfo:LPBFO_00710 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

