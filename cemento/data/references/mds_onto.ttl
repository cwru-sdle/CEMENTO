    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "The exhaust (air) is an output produced in a process, which can not use again. The quantity of exhaust (air) is assumed the same as compressed air at the input of the same process."@en ;
    skos:exactMatch lpbfo:LPBFO_00814 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-LPBF" .

