mds:ChemicalSynthesis a owl:Class ;
    rdfs:label "ChemicalSynthesis"@en ;
    rdfs:subClassOf mds:ChemicalReaction ;
    skos:altLabel "Synthesis"@en ;
    skos:definition "A chemical synthesis is a chemical reaction that involves smaller molecules reacted or transformed to produce a larger molecule. [Wikipedia] "@en ;
