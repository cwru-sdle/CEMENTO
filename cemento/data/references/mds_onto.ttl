mds:SelectiveLaserMelting a owl:Class ;
    rdfs:label "SelectiveLaserMelting"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:isDefinedBy " ISO/ASTM 52900"@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "According to ISO/ASTM 52900, the Selective Laser Melting process is now commonly called LaserPowderBedFusion (L-PBF). Additive manufacturing process, in which thermal energy provided by a laser specifically melts areas of a powder bed."@en ;
    skos:exactMatch lpbfo:LPBFO_00005 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Material-LPBF" .

mds:Selectivity a owl:Class ;
    rdfs:label "Selectivity"@en ;
    rdfs:subClassOf obo:BFO_0000016 ;
    skos:altLabel " " ;
    skos:definition "It sometimes refers to the discrimination shown by a given reactant A when it reacts with two alternative reactants B and C, or in two different ways (e.g. at two different sites) with a reactant B. The term also sometimes refers to the ratio of products obtained from given reactants. This meaning is of importance for catalysts, which can have a wide range of selectivities. Selectivity is quantitatively expressed by ratios of rate constants for the alternative reactions, or by the decadic logarithms of such ratios.[IUPAC]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage " " ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://doi.org/10.1351/goldbook.S05563"@en .

mds:Semiconductor rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( mds:Material
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty mds:hasElectronicBandGap ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( mds:ElectronicBandGap
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty mds:hasValue ;
                                                                                                           owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                                                                owl:onDatatype xsd:float ;
                                                                                                                                owl:withRestrictions ( [ xsd:minInclusive "0.5"^^xsd:float
                                                                                                                                                       ]
                                                                                                                                                       [ xsd:maxInclusive "3.0"^^xsd:float
                                                                                                                                                       ]
                                                                                                                                                     )
                                                                                                                              ]
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty mds:unit ;
                                                               owl:hasValue unit:EV
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf mds:Material ;
                  rdfs:label "Semiconductor" ;
                  skos:definition "A Material with Electronic Band Gap between 0.5 eV and 3.0 eV" .

