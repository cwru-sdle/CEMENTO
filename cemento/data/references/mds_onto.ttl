obo:CHMO_0000113 a owl:Class ;
    rdfs:label "atomic force microscopy" ;
    rdfs:subClassOf obo:CHMO_0000112 ;
    skos:altLabel "AFM",
        "SFM",
        "atomic force imaging",
        "scanning force microscopy" ;
    skos:definition "Microscopy which uses a sharp spike (known as a 'tip') mounted on the end of a cantilever to scan the surface of the specimen. An image of the surface is obtained by mechanically moving the probe in a raster scan of the specimen, line by line, and recording the force experienced by the tip as a function of position. A feedback loop is used to maintain a fixed relationship between the tip and surface during scanning.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0000142 a owl:Class ;
    rdfs:label "electron diffraction"@en ;
    rdfs:subClassOf obo:CHMO_0000141 ;
    skos:altLabel "ED"@en ;
    skos:definition "A method for determining structure by directing a beam of electrons (the energies of which are controlled by their acceleration voltage) and recording the resulting diffraction pattern.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000156 a owl:Class ;
    rdfs:label "Xray diffraction"@en ;
    rdfs:subClassOf obo:CHMO_0000141 ;
    skos:altLabel "XRD"@en ;
    skos:definition "A method for determining structure by directing a beam of X-rays at the sample and detecting the positions and intensities of the diffracted X-rays as a pattern of spots on a photographic plate.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000323 a owl:Class ;
    rdfs:label "circular dichroism spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0000775 ;
    skos:altLabel "CD"@en ;
    skos:definition "Spectroscopy based on the differential absorption of left- and right-handed circularly polarised light by a sample.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000328 a owl:Class ;
    rdfs:label "electron spin resonance spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0000743 ;
    skos:altLabel "EPR"@en ;
    skos:definition "Spectroscopy where the response of an atom with an unpaired electron to a perturbing magnetic field is measured.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000497 a owl:Class ;
    rdfs:label "gas chromatography-mass spectrometry"@en ;
    rdfs:subClassOf obo:CHMO_0000470 ;
    skos:altLabel "GCMS"@en ;
    skos:definition "Any method where a sample mixture is first separated by gas chromatography then ionised and characterised according to mass-to-charge ratio and relative abundance.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000498 a owl:Class ;
    rdfs:label "high resolution mass spectrometry"@en ;
    rdfs:subClassOf obo:CHMO_0000470 ;
    skos:altLabel "HRMS"@en ;
    skos:definition "Mass spectrometry where the \"exact\" mass of the molecular ions in the sample is determined as opposed to the \"nominal\" mass (the number of protons and neutrons). [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000524 a owl:Class ;
    rdfs:label "liquid chromatography-mass spectrometry"@en ;
    rdfs:subClassOf obo:CHMO_0000470 ;
    skos:altLabel "LCMS"@en ;
    skos:definition "A method where a sample mixture is first separated by liquid chromatography before being converted into ions which are characterised by their mass-to-charge ratio and relative abundance.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000593 a owl:Class ;
    rdfs:label "1H nuclear magnetic resonance spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0000613 ;
    skos:altLabel "1H NMR Spectroscopy"@en ;
    skos:definition "Spectroscopy where the energy states of 1H nuclei placed in a static magnetic field are interrogated by inducing transitions between the states via radio frequency irradiation. Each experiment consists of a sequence of radio frequency pulses with delay periods in between them."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Proton_nuclear_magnetic_resonance"@en .

obo:CHMO_0000595 a owl:Class ;
    rdfs:label "13C nuclear magnetic resonance spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0000613 ;
    skos:altLabel "13C NMR Spectroscopy"@en ;
    skos:definition "Spectroscopy where the energy states of 13C nuclei placed in a static magnetic field are interrogated by inducing transitions between the states via radio frequency irradiation. Each experiment consists of a sequence of radio frequency pulses with delay periods in between them."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Carbon-13_nuclear_magnetic_resonance"@en .

obo:CHMO_0000630 a owl:Class ;
    rdfs:label "infrared absorption spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0000628 ;
    skos:altLabel "IR"@en ;
    skos:definition "Spectroscopy where the sample absorbs radiation from the infrared region (0.78 to 1000 micrometres). [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000656 a owl:Class ;
    rdfs:label "Raman spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0002414 ;
    skos:altLabel "Raman scattering spectroscopy"@en ;
    skos:definition "Spectroscopy where the Raman scattering of monochromatic light, usually from a laser in the visible, near infrared, or near ultraviolet range by a sample is detected."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000779 a owl:Class ;
    rdfs:label "polarimetry"@en ;
    rdfs:subClassOf obo:CHMO_0000208 ;
    skos:altLabel "optical rotation measurement"@en ;
    skos:definition "The measurement of the extent to which a sample interacts with polarized electromagnetic radiation by transmission, reflection, refraction, or diffraction.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0000951 a owl:Class ;
    rdfs:label "atomic force microscopy tip" ;
    rdfs:subClassOf obo:OBI_0000968 ;
    skos:definition "A sharp spike which is mounted on the end of a cantilever and used to scan the surface of a specimen in atomic force microscopy.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0000952 a owl:Class ;
    rdfs:label "atomic force microscopy cantilever" ;
    rdfs:subClassOf obo:OBI_0000968 ;
    skos:altLabel "AFM cantilever",
        "AFM lever" ;
    skos:definition "A cantilever used in atomic force microscopy to transmit force from the tip to a recording device.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0000954 a owl:Class ;
    rdfs:label "atomic force microscope" ;
    rdfs:subClassOf obo:CHMO_0000953 ;
    skos:definition "A microscope which uses a sharp spike (known as a 'tip') mounted on the end of a cantilever to scan the surface of the specimen. An image of the surface is obtained by mechanically moving the probe in a raster scan of the specimen, line by line, and recording the force experienced by the tip as a function of position. A feedback loop is used to maintain a fixed relationship between the tip and surface during scanning.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0001000 a owl:Class ;
    rdfs:label "chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0000999 ;
    skos:definition "A separation method where the components are distributed between two phases, one of which is stationary, while the other moves in a definite direction. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001002 a owl:Class ;
    rdfs:label "gas chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0001001 ;
    skos:altLabel "GC"@en ;
    skos:definition "Column chromatography where the mobile phase is a gas. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001003 a owl:Class ;
    rdfs:label "supercritical fluid chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0001001 ;
    skos:altLabel "SFC"@en ;
    skos:definition "Column chromatography where the mobile phase is a fluid above and relatively close to its critical temperature and pressure.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001004 a owl:Class ;
    rdfs:label "liquid chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0001001 ;
    skos:altLabel "LC"@en ;
    skos:definition "Column chromatography where the mobile phase is a liquid. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001007 a owl:Class ;
    rdfs:label "thin layer chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0001005 ;
    skos:altLabel "TLC"@en ;
    skos:definition "A chromatography method where the stationary phase is a thin (0.10 to 0.25 mm) layer of sorbent applied to a firm backing such as glass, aluminium or plastic sheet. An eluent ( single solvent or solvent mixture) is allowed to flow by capillary action through the sorbent starting at a point just below the applied samples. As the eluent front migrates through the sorbent the components of the sample also migrate, but at different rates resulting in separation. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001009 a owl:Class ;
    rdfs:label "high-performance liquid chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0002318 ;
    skos:altLabel "HPLC"@en ;
    skos:definition "Column chromatography where the mobile phase is a liquid, the stationary phase consists of very small particles and the inlet pressure is relatively high.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001253 a owl:Class ;
    rdfs:label "ultraviolet spectrophotometry"@en ;
    rdfs:subClassOf obo:CHMO_0000292 ;
    skos:altLabel "UV Spectroscopy"@en ;
    skos:definition "Spectroscopy where the sample absorbs radiation from the ultraviolet region (190–400 nm) resulting in electronic transitions within the sample. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001532 a owl:Class ;
    rdfs:label "distillation"@en ;
    rdfs:subClassOf obo:OBI_0000094 ;
    skos:definition "Distillation is a method of separating mixtures based on differences in their volatilities in a boiling liquid mixture. The components in a sample mixture are vaporized by the application of heat and then cooled by the action of cold water in a condenser. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing",
        "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001554 a owl:Class ;
    rdfs:label "oven drying"@en ;
    rdfs:subClassOf obo:CHMO_0001549 ;
    skos:definition "The removal of solvent from a sample by heating in an oven. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001557 a owl:Class ;
    rdfs:label "vacuum drying"@en ;
    rdfs:subClassOf obo:CHMO_0001549 ;
    skos:definition "The removal of water (or other solvents) from a sample by placing it under reduced pressure. This allows water (or other solvents) to evaporate from (heat-sensitive) samples at a lower temperature. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001576 a owl:Class ;
    rdfs:label "rotary evaporation"@en ;
    rdfs:subClassOf obo:CHMO_0002208 ;
    skos:definition "The removal of solvent from a sample by applying heat and lowering the pressure above the sample whilst rotating it at 10-300 rpm. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001577 a owl:Class ;
    rdfs:label "extraction"@en ;
    rdfs:subClassOf obo:OBI_0000094 ;
    skos:definition "Extraction is the transfer of a solute from a liquid phase to another immiscible or partially-miscible liquid phase in contact with it. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001640 a owl:Class ;
    rdfs:label "filtration"@en ;
    rdfs:subClassOf obo:CHMO_0002231 ;
    skos:definition "The process of segregation of phases; the separation of suspended solids from a liquid or gas, usually by forcing a carrier gas or liquid through a porous medium. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing",
        "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001654 a owl:Class ;
    rdfs:label "ball milling"@en ;
    rdfs:subClassOf obo:CHMO_0002774 ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001682 a owl:Class ;
    rdfs:label "sample melting"@en ;
    rdfs:subClassOf obo:OBI_0000094 ;
    skos:altLabel "MP"@en ;
    skos:definition "The process of heating a substance to cause the solid–liquid phase change.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001707 a owl:Class ;
    rdfs:label "sonication"@en ;
    rdfs:subClassOf obo:OBI_0000094 ;
    skos:definition "The irradiation of a liquid sample with sound (20 Hz-20 kHz) waves resulting in agitation. Sound waves propagate into the liquid media result in alternating high-pressure (compression) and low-pressure (rarefaction) cycles. During rarefaction, high-intensity sonic waves create small vacuum bubbles or voids in the liquid, which then collapse violently (cavitation) during compression, creating very high local temperatures.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis",
        "Materials Processing",
        "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001718 a owl:Class ;
    rdfs:label "evaporative light scattering detection"@en ;
    rdfs:subClassOf obo:CHMO_0001709 ;
    skos:altLabel "ELSD"@en ;
    skos:definition "A detection method where a liquid containing the sample is atomised in a gas, forming small droplets which are allowed to evaporate leaving the sample as fine particles. The suspended particles pass through a light beam and the scattered light transmitted by the particles is sensed by a photomultiplier. The response is proportional to the mass of the molecules in the sample.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002004 a owl:Class ;
    rdfs:label "two dimensional chromatography-mass spectrometry"@en ;
    rdfs:subClassOf obo:CHMO_0000470 ;
    skos:definition "A method in which a two-dimensional chromatography method is coupled to mass spectrometry. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002171 a owl:Class ;
    rdfs:label "phase atomic force micrograph" ;
    rdfs:subClassOf obo:CHMO_0002170 ;
    skos:altLabel "phase AFM image",
        "phase atomic force microscope (AFM) image",
        "phase atomic force microscopy image" ;
    skos:definition "An image obtained by using a sharp spike (known as a 'tip') mounted on the end of a cantilever to scan the surface of the specimen, line by line, and recording the drop in amplitude of the oscillating cantilever as a function of position.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0002173 a owl:Class ;
    rdfs:label "amplitude atomic force micrograph" ;
    rdfs:subClassOf obo:CHMO_0002170 ;
    skos:altLabel "amplitude AFM image",
        "amplitude atomic force microscope image",
        "amplitude atomic force microscopy images" ;
    skos:definition "An image obtained by using a sharp spike (known as a 'tip') mounted on the end of a cantilever to scan the surface of the specimen, line by line, and recording the deflection of the tip as a function of position.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0002391 a owl:Class ;
    rdfs:label "selected ion chromatogram"@en ;
    rdfs:subClassOf obo:CHMO_0002388 ;
    skos:altLabel "extracted ion chromatogram"@en ;
    skos:definition "A plot of ion current vs. retention time obtained from a chromatography experiment with mass detection. A small mass window is monitored such that the mass chromatogram represents detection of a very specific mass-to-charge ratio.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002444 a owl:Class ;
    rdfs:label "microwave"@en ;
    rdfs:subClassOf obo:OBI_0000968 ;
    skos:altLabel "microwave oven"@en ;
    skos:definition "A piece of apparatus, consisting of a high- voltage transformer, a cavity magnetron, a waveguide and a sample chamber, that is used to heat samples by irradiation with microwave (2 GHz) radiation.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002572 a owl:Class ;
    rdfs:label "Schlenk tube"@en ;
    rdfs:subClassOf obo:OBI_0000968 ;
    skos:altLabel "Schlenk flask"@en ;
    skos:definition "A piece of apparatus used as a reaction vessel in air-sensitive chemistry. It is made of glass and has a side arm fitted with a PTFE or ground glass stopcock which allows the vessel to be evacuated or filled with gas (e.g. nitrogen or argon).[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis",
        "Tool" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002582 a owl:Class ;
    rdfs:label "flash chromatography"@en ;
    rdfs:subClassOf obo:CHMO_0001001 ;
    skos:definition "A type of column chromatography where 0.1-10 g of sample mixture is separated in less than 15 min by using pressurised gas to drive the mobile phase through the column. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002685 a owl:Class ;
    rdfs:label "atomic force microscopy height profile" ;
    rdfs:subClassOf obo:CHMO_0000800 ;
    skos:altLabel "AFM height profile" ;
    skos:definition "A plot of vertical displacement vs. distance obtained by using a sharp spike (known as a 'tip') mounted on the end of a cantilever to scan the surface of the specimen, line by line, and recording the force experienced by the tip as a function of position.[CHMO]" ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Material-AFM" .

obo:CHMO_0002771 a owl:Class ;
