cco:ont00000253 a owl:Class ;
    rdfs:label "Information Bearing Entity"@en ;
    skos:exactMatch cco:ont00000253 ;
    mds:hasStudyStage "Sample" .

cco:ont00000853 a owl:Class ;
    rdfs:label "Descriptive Information Content Entity"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    owl:disjointWith cco:ont00000965 ;
    skos:altLabel "Descriptive ICE"@en ;
    skos:definition "An Information Content Entity that consists of a set of propositions that describe some Entity."@en ;
    skos:exactMatch cco:ont00000853 ;
    mds:hasStudyStage "Result" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

obo:BFO_0000035 a owl:Class ;
    rdfs:label "Process Boundary"@en ;
    rdfs:subClassOf obo:BFO_0000003 ;
    skos:definition "P is a process boundary =Def. p is a temporal part of a process & p has no proper temporal parts."@en ;
    skos:example "the boundary between the 2nd and 3rd year of your life."@en .

obo:BFO_0000145 a owl:Class ;
    rdfs:label "relational quality"@en ;
    dc:identifier "057-BFO" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "b is a relational quality =Def b is a quality & there exists c and d such that c and d are not identical & b specifically depends on c & b specifically depends on d"@en ;
    skos:example "A marriage bond; an instance of love; an obligation between one person and another"@en ;
    mds:hasStudyStage "Sample" .

mds:ElectricalWire a owl:Class ;
    rdfs:label "ElectricalWire" ;
    rdfs:subClassOf cco:ont00000663 ;
    skos:altLabel "Electrical Cable" ;
    skos:definition "A power transmission artifact made of conductive material that carries charge from one location to another." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain " " .

mds:MaterialProperty a owl:Class ;
    rdfs:label "MaterialProperty" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel " " ;
    skos:definition "A Quality of a material that describes the relation between the strength or the change in strength of an applied field (magnetic, electric, mechanical stress, etc...) and the strength of the response to that field or to the change in that field in the material, or the extent or nature of chemical changes of a material in response to the presence of some gaseous or liquid substance." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain " " .

mds:Number a owl:Class ;
    rdfs:label "Number" ;
    rdfs:subClassOf cco:ont00000768 ;
    skos:altLabel "num" ;
    skos:definition "Total number of a particular entity." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Result" ;
    mds:hasSubDomain " " .

cco:ont00000529 a owl:Class ;
    rdfs:label "Date Identifier"@en ;
    rdfs:subClassOf cco:ont00000073 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( cco:ont00000073 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001916 ;
                        owl:someValuesFrom cco:ont00000800 ] ) ],
        [ a owl:Class ;
            owl:intersectionOf ( cco:ont00000073 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001916 ;
                        owl:someValuesFrom cco:ont00000800 ] ) ],
        [ a owl:Class ;
            owl:intersectionOf ( cco:ont00000073 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001916 ;
                        owl:someValuesFrom cco:ont00000800 ] ) ] ;
    skos:altLabel "Day Identifier"@en ;
