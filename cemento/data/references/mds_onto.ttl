    rdfs:label "Information Content Entity"@en ;
    skos:exactMatch cco:ont00000958 ;
    mds:hasStudyStage "Result" .

cco:ont00000965 a owl:Class ;
    rdfs:label "Directive Information Content Entity"@en ;
    skos:exactMatch cco:ont00000965 ;
