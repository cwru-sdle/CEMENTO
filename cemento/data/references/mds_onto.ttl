#### PROCESSING METHODS


mds:CompressionMolding a owl:Class ;
    rdfs:label "CompressionMolding"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Compression molding is a process where pre-measured silicone places in a heated mold and compressed to shape"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:TransferMolding a owl:Class ;
    rdfs:label "TransferMolding"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Transfer molding is a process where silicone preform placed in a chamber and forced into a closed mold by a plunger"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:InjectionMolding a owl:Class ;
    rdfs:label "InjectionMolding"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Injection molding is a process where liquid silicone rubber injected into a closed mold under pressure"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Extrusion a owl:Class ;
    rdfs:label "Extrusion"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Extrusion is a process where silicone compound forced through a die to create continuous profiles"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Calendering a owl:Class ;
    rdfs:label "Calendering"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Calendering is a process where silicone compound passed through rollers to form sheets or films"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Casting a owl:Class ;
    rdfs:label "Casting"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Casting is a process where liquid silicone poured into open or closed molds and cured"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:DipMolding a owl:Class ;
    rdfs:label "DipMolding"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "Coating"@en ;
    skos:definition "Dip molding (or coating) is a process where substrate dipped into liquid silicone, then cured"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:3DPrinting a owl:Class ;
    rdfs:label "3DPrinting"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "Additive Manufacturing" ;
    skos:definition "3D printing or additive manufacturing (AM) is a process with ayer-by-layer fabrication using silicone-based inks or resins"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Laminating a owl:Class ;
    rdfs:label "Laminating"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "" ;
    skos:definition "Laminating is a process where silicone applied as a coating to fabrics, papers, or other substrates"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Foaming a owl:Class ;
    rdfs:label "Foaming"@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:altLabel "Expansion Molding"@en ;
    skos:definition "Foaming is a process where silicone formulated with blowing agents to create foamed parts"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

#### MECHANICAL PROPERTIES


mds:WorkingTime a owl:Class ;
    rdfs:label "WorkingTime"@en ;
    rdfs:subClassOf mds:ElapsedTime ,
        mds:MechanicalProperty ;
    skos:altLabel "PotLife" ;
    skos:definition "Working time is an elapsed time after mixing during which the material or formulation remains processable. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:YieldStress a owl:Class ;
    rdfs:label "YieldStress"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Yield stress is the minimum stress required to initiate flow; important for dispensing and molding. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Thixotropy a owl:Class ;
    rdfs:label "Thixotropy"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Time-dependent shear thinning; affects flow and leveling during processing. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Hardness a owl:Class ;
    rdfs:label "Hardness"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Hardness is a mechanical property of a material that indicates resistance to indentation; indicates stiffness. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:TensileStrength a owl:Class ;
    rdfs:label "TensileStrength"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Tensile strength is a mechanical property measured in a material that indicates the maximum stress in the material before breaking. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ElongationAtBreak a owl:Class ;
    rdfs:label "ElongationAtBreak"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Elongation at break is a mechanical property measured in a material that is stretched to a percentage before failure. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:TearStrength a owl:Class ;
    rdfs:label "TearStrength"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Tear strength is a mechanical property measured in a material that indicates resistance to propagation of a tear. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:CompressionSet a owl:Class ;
    rdfs:label "CompressionSet"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:Measurement , 
        mds:AnalyticalResult;
    skos:altLabel "" ;
    skos:definition "Compression set is a mechanical property of a material that indicates the permanent deformation in the material after compression. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Resilience a owl:Class ;
    rdfs:label "Resilience"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "Rebound" ;
    skos:definition "Elastic recovery after deformation. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Modulus a owl:Class ;
    rdfs:label "Modulus"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:Measurement , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Modulus is a mechanical property measured from a characterization that indicates a material's resistance to deformation when a force is applied. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PermanentSet a owl:Class ;
    rdfs:label "PermanentSet"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:Measurement , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Permanent set is a mechanical property of a material that designates residual deformation after the material is stretched. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:LowTemperatureFlexibility a owl:Class ;
    rdfs:label "LowTemperatureFlexibility"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Flexibility at sub-ambient temperatures. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:CompressionModulus a owl:Class ;
    rdfs:label "CompressionModulus"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Compression modulus is a mechanical property of a material that indicates its stiffness in response to compressive stress, i.e. resistance to being compressed. "@en ;
    rdfs:comment "The compression modulus is calculated by dividing the applied compressive stress (force divided by area) by the resulting compressive strain (change in length divided by original length). "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasSubDomain "Chem-Form"@en .

mds:SurfaceRoughness a owl:Class ;
    rdfs:label "SurfaceRoughness"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Texture or smoothness of the surface"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Viscosity a owl:Class ;
    rdfs:label "Viscosity"@en ;
    rdfs:comment "This term is reused from Allotrope Foundation Result Ontology. "@en ;
    skos:exactMatch afr:AFR_0002641 ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Resistance to flow"@en ;
    skos:scopeNote "This property is a measured result for an uncured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ElasticModulus a owl:Class ;
    rdfs:label "ElasticModulus" ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Elastic modulus is a measure of a material's stiffness, quantifying its resistance to elastic deformation under stress. I.e. It is the proportionality constant between stress and strain, expressed by the formula. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ShearModulus a owl:Class ;
    rdfs:label "ShearModulus" ;
    rdfs:subClassOf mds:ElasticModulus ;
    skos:altLabel " " ;
    skos:definition "Shear modulus is an elastic modulus used for shear stress, which involves forces parallel to a surface."@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:YoungModulus a owl:Class ;
    rdfs:label "YoungModulus"@en ;
    rdfs:subClassOf mds:ElasticModulus ;
    skos:altLabel "" ;
    skos:definition "Young's Modulus is elastic modulus used for tensile or compressive stress and strain."@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:UltimateTensileStrength a owl:Class ;
    rdfs:label "UltimateTensileStrength"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel ""@en ;
    skos:definition "Maximum stress endured by a polymer before it breaks"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Toughness a owl:Class ;
    rdfs:label "Toughness"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Ability for a polymer to deform plastically before fracture"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:LossModulus a owl:Class ;
    rdfs:label "LossModulus"@en ;
    rdfs:subClassOf mds:Modulus ;
    skos:altLabel "" ;
    skos:definition "A measurement of the material's viscous behavior by energy loss as heat during deformation. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:StorageModulus a owl:Class ;
    rdfs:label "StorageModulus"@en ;
    rdfs:subClassOf mds:Modulus ;
    skos:altLabel "" ;
    skos:definition "A measurement of the material's elasticity by energy stored and recoverd during deformation. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:TanDelta a owl:Class ;
    rdfs:label "TanDelta"@en ;
    rdfs:subClassOf mds:MechanicalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Tan delta is a ratio of loss modulus to storage modulus. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Viscoelasticity a owl:Class ;
    rdfs:label "Viscoelasticity"@en ;
    rdfs:subClassOf mds:PolymerCharacteristic ,
        mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:defiition "A property where a polymer acts as a fluid and solid, combining viscous and elastic behaviors. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ,
        "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Elasticity a owl:Class ;
    rdfs:label "Elasticity"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Ability for a polymer to deform under stress and return to its original shape after. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ,
        "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Plasticity a owl:Class ;
    rdfs:label "Plasticity"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Ability for a polymer to undergo permanent deformation without fracturing. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ,
        "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Stiffness a owl:Class ;
    rdfs:label "Stiffness"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "A polymer's resistance to deformation under stress. "@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ,
        "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:BulkModulus a owl:Class ;
    rdfs:label "BulkModulus" ;
    rdfs:subClassOf mds:Modulus ;
    skos:altLabel "" ;
    skos:definition "Bulk modulus is a measurement of a material's resistance to uniform compression. It is used for volumetric stress and strain, where a force is applied uniformly in all directions."@en ;
    skos:scopeNote "This property is a measured result for a cured polymer and formulation. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Durometer a owl:Class ;
    rdfs:label "Durometer"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Measurement of a polymer's hardness at a point of indentation"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

