    rdfs:subClassOf mds:ChemicalProperty ;
    skos:altLabel "" ;
    skos:definition "Change in properties after heat exposure"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:FlameResistance a owl:Class ;
    rdfs:label "FlameResistance"@en ;
    rdfs:subClassOf mds:ChemicalProperty ;
    skos:altLabel "" ;
    skos:definition "Resistance to ignition and burning"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

#### PHYSICAL PROPERTIES

mds:MixViscosityProfile a owl:Class ;
    rdfs:label "MixViscosityProfile"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Change in viscosity over time after mixing (shows onset of cure)"@en ;
    skos:scopeNote "This property is a measured result for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:VolatileContent a owl:Class ;
    rdfs:label "VolatileContent"@en ;
    rdfs:subClassOf cco:ont00000845 ,
        mds:AnalyticalResult ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Volatile content designates the amount of volatile materials in a sample expressed relatively to the whole content"@en ;
    skos:scopeNote "This property is a measured result  for both cured and uncured polymers"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:SpecificGravity a owl:Class ;
    rdfs:label "SpecificGravity"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Density relative to water; useful for batch consistency and formulation control"@en ;
    skos:scopeNote "This property is a measured result for both cured and uncured polymers"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:FillerContent a owl:Class ;
    rdfs:label "FillerContent"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        cco:ont00000845 ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Filler content is a percentage of reinforcing/extending fillers in a formulation and it impacts flow, mechanical properties"@en ;
    skos:scopeNote "This property is a measured result for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:MoistureContent a owl:Class ;
    rdfs:label "MoistureContent"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        cco:ont00000845 ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Moisture content designates the percentage of water present in the mixture of formulation and it affects cure and final properties"@en ;
    skos:scopeNote "This property is a measured result for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:MixHomogeneity a owl:Class ;
    rdfs:label "MixHomogeneity"@en ;
    rdfs:subClassOf mds:AnalyticalResult,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Uniformity of the mixture; affects downstream properties and cure"@en ;
    skos:scopeNote "This property is a measured result for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ShelfLife a owl:Class ;
    rdfs:label "ShelfLife"@en ;
    rdfs:subClassOf mds:ElapsedTime ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Shelflife is a physical property and the elapsed time the undured mixture remains usable under specified storage conditions"@en ;
    skos:scopeNote "This property is a measured result  for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Hardness a owl:Class ;
    rdfs:label "Hardness"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:exactMatch cco:ont00000766 ;
    skos:definition "A Mechanical Property quantifying the degree in which a material resists localized plastic deformation."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:TensileStrength a owl:Class ;
    rdfs:label "TensileStrength"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Maximum stress before breaking"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ElongationAtBreak a owl:Class ;
    rdfs:label "ElongationAtBreak"@en ;
    rdfs:subClassOf mds:MechanicalProperty;
    skos:altLabel "" ;
    skos:definition "Stretch percentage before failure"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:TearStrength a owl:Class ;
    rdfs:label "TearStrength"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Resistance to propagation of a tear"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:CompressionSet a owl:Class ;
    rdfs:label "CompressionSet"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:Measurement ;
    skos:altLabel "" ;
    skos:definition "Permanent deformation after compression"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Resilience a owl:Class ;
    rdfs:label "Resilience"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "Rebound" ;
    skos:definition "Elastic recovery after deformation"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Modulus a owl:Class ;
    rdfs:label "Modulus"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:Measurement ;
    skos:altLabel "" ;
    skos:definition "Stress at a specified strain"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PermanentSet a owl:Class ;
    rdfs:label "PermanentSet"@en ;
    rdfs:subClassOf mds:MechanicalProperty ,
        mds:Measurement ;
    skos:altLabel "" ;
    skos:definition "Residual deformation after stretching"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:HeatAgingProperties a owl:Class ;
    rdfs:label "HeatAgingProperties"@en ;
    rdfs:subClassOf mds:ChemicalProperty ;
    skos:altLabel "" ;
    skos:definition "Change in properties after heat exposure"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:LowTemperatureFlexibility a owl:Class ;
    rdfs:label "LowTemperatureFlexibility"@en ;
    rdfs:subClassOf mds:MechanicalProperty ;
    skos:altLabel "" ;
    skos:definition "Flexibility at sub-ambient temperatures"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ElectricalResistivity a owl:Class ;
    rdfs:label "ElectricalResistivity"@en ;
    rdfs:subClassOf mds:ElectricalProperty ;
    skos:altLabel "" ;
    skos:definition "Volume and surface resistivity"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:DielectricStrength a owl:Class ;
    rdfs:label "DielectricStrength"@en ;
    rdfs:subClassOf mds:ElectricalProperty ;
    skos:altLabel "" ;
    skos:definition "Maximum voltage withstand before breakdown"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:DielectricConstant a owl:Class ;
    rdfs:label "DielectricConstant"@en ;
    rdfs:subClassOf mds:ElectricalProperty ;
    skos:altLabel "" ;
    skos:definition "Electrical permittivity"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:FlameResistance a owl:Class ;
    rdfs:label "FlameResistance"@en ;
    rdfs:subClassOf mds:ChemicalProperty ;
    skos:altLabel "" ;
    skos:definition "Resistance to ignition and burning"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:WaterAbsorption a owl:Class ;
    rdfs:label "WaterAbsorption"@en ;
    rdfs:subClassOf mds:PhysicalProperty ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Water absorption is measured as a percentage of weight change from the uptake of water by a material under specified conditions"@en ;
    skos:scopeNote "This property is a measured result  for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:WeatheringResistance a owl:Class ;
    rdfs:label "WeatheringResistance"@en ;
    rdfs:subClassOf mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Property retention after UV, ozone, or outdoor conditions"@en ;
    skos:scopeNote "This property is for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:AdhesionToSubstrate a owl:Class ;
    rdfs:label "AdhesionToSubstrate"@en ;
    rdfs:subClassOf mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Bond strength to other materials"@en ;
    skos:scopeNote "This property is a measured result  for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PolymerDispersityIndex a owl:Class ;
    rdfs:label "PolymerDispersityIndex"@en ;
    rdfs:subClassOf mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "A measurement of the distribution of molecular weights in a polymer"@en ;
    skos:scopeNote "This property is a measured result for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:CrosslinkDensity a owl:Class ;
    rdfs:label "CrosslinkDensity"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        mds:PhysicalProperty ;
    skos:altLabel "" ;
    skos:definition "Number of effective crosslinks per unit volume of a material" ;
    skos:scopeNote "This property is a measured result  for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:GlassTransitionTemperature a owl:Class ;
    rdfs:label "GlassTransitionTemperature"@en ;
    rdfs:subClassOf mds:AnalyticalResult ,
        mds:PhysicalProperty;
    skos:altLabel "" ;
    skos:definition "Temperature at which an amorphous polymer transitions from a hard, glassy state to a soft, rubbery state"@en ;
    skos:scopeNote "This property is a measured result for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

#### OPTICAL PROPERTIES

mds:Color a owl:Class ;
    rdfs:label "Color"@en ;
    rdfs:subClassOf cco:ont00000784 ;
    skos:exactMatch cco:ont00000378 ;
    skos:altLabel "Appearance"@en ;
    skos:definition "Visual assessment; important for color-critical or optical applications"@en,
    "Visual or instrumental color measurement"@en ;
    skos:scopeNote "This is for both cured and uncured polymers"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Transparency a owl:Class ;
    rdfs:label "Transparency"@en ;
    rdfs:subClassOf cco:ont00000784 ;
    skos:altLabel "Transmittance" ;
    skos:definition "Light transmission through the material"@en ;
    skos:scopeNote "This is for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .


#### ELECTRICAL PROPERTIES

mds:ElectricalResistivity a owl:Class ;
    rdfs:label "ElectricalResistivity"@en ;
    rdfs:subClassOf mds:ElectricalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Volume and surface resistivity"@en ;
    skos:scopeNote "This is for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:DielectricStrength a owl:Class ;
    rdfs:label "DielectricStrength"@en ;
    rdfs:subClassOf mds:ElectricalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Maximum voltage withstand before breakdown"@en ;
    skos:scopeNote "This is for a cured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:DielectricConstant a owl:Class ;
    rdfs:label "DielectricConstant"@en ;
    rdfs:subClassOf mds:ElectricalProperty , 
        mds:AnalyticalResult ;
    skos:altLabel "Relative permittivity" ;
    skos:definition "Dielectric constant is also known as relative permittivity and it is a measure of a measure of a material's ability to store electrical energy in an electric field compared to a vacuum. "@en ;
    rdfs:comment "It is defined as the ratio of a capacitor's capacitance with a dielectric material to its capacitance with a vacuum, or the ratio of the material's permittivity to the permittivity of free space. A higher dielectric constant indicates that a material is better at insulating and storing charge, while a lower constant means it is closer to a vacuum's insulating properties."@en ;
    skos:scopeNote "This property is for a cured polymer. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

#### RELATED TO PROPERTIES

mds:EnergyLoss a owl:Class ;
    rdfs:label "EnergyLoss"@en ;
    rdfs:subClassOf mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Dissipation of energy in a polymer through a degradation process. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ;
    mds:hasSubDomain "Chem-Form"@en .

#### POLYMER

mds:Polymerization a owl:Class ;
    rdfs:label "Polymerization"@en ;
    rdfs:subClassOf mds:ChemicalReaction ;
    skos:altLabel "" ;
    skos:definition "A polymerization is a chemical reaction processing during which monomers (of the same type or different types) are bonded into oligomers (short chains < 10 repeating units) or polymers (long chains > 10 repeating units) and it may requires a catalyst"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:StepGrowthPolymerization a owl:Class ;
    rdfs:label "StepGrowthPolymerization"@en ;
    rdfs:subClassOf mds:Polymerization ;
    skos:altLabel "Step-growth polymerization" ;
    skos:definition "A step-growth polymerization is a type of polymerization where polymers are formed stepwise. I.e. a polymer's length increases in chunks at a time"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ChainGrowthPolymerization a owl:Class ;
    rdfs:label "ChainGrowthPolymerization"@en ;
    rdfs:subClassOf mds:Polymerization ;
    skos:altLabel "Chain-growth polymerization" ;
    skos:definition "A chain-growth polymerization is a type of polymerization where monomers are added to an active center one by one to form an oligomer or polymer. I.e. the polymer grows one monomer at a time"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PlasmaPolymerization a owl:Class ;
    rdfs:label "PlasmaPolymerization"@en ;
    rdfs:subClassOf mds:Polymerization ;
    skos:altLabel "" ;
    skos:definition "The process of using plasma to create a thin polymer coating"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PolymerStructure a owl:Class ;
    rdfs:label "PolymerStructure"@en ;
    rdfs:subClassOf cco:ont00001059 ;
    skos:altLabel "" ;
    skos:definition "Polymer structure is a realizable entity that describes how monomers are connected in a polymer. Polymer structure has a great impact on the properties of the polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Linear a owl:Class ;
    rdfs:label "Linear"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer structure formed of a long single chain"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Branched a owl:Class ;
    rdfs:label "Branched"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer structure formed of main backbone with short branches off of it"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Star a owl:Class ;
    rdfs:label "Star"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer structure with several linear chains connected by a central core"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:CombPolymer a owl:Class ;
    rdfs:label "CombPolymer"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer structure formed of a main backbone and multiple (evenly spaced) side chains"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:DendronizedPolymer a owl:Class ;
    rdfs:label "DendronizedPolymer"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer structure of a main backbone and branched dendrons on every repeating unit"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:LadderPolymer a owl:Class ;
    rdfs:label "LadderPolymer"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer structure formed of a double-stranded backbone connected by fused rings"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Dendrimer a owl:Class ;
    rdfs:label "Dendrimer"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A synthetic polymer formed of a branched, tree-like structure from a central core"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:EndGroup a owl:Class ;
    rdfs:label "EndGroup"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "Functional group located at the end of a polymer chain"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PendantGroup a owl:Class ;
    rdfs:label "PendantGroup"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "Additional group of atoms attached to the main backbone of a polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Copolymer a owl:Class ;
    rdfs:label "Copolymer"@en ;
    rdfs:subClassOf mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A polymer made from two or more types of monomer units"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:RandomCopolymer a owl:Class ;
    rdfs:label "RandomCopolymer"@en ;
    rdfs:subClassOf mds:Copolymer,
        mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A copolymer of monomers in random arrangement"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:AlternatingCopolymer a owl:Class ;
    rdfs:label "AlternatingCopolymer"@en ;
    rdfs:subClassOf mds:Copolymer,
        mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A copolymer of monomers in an alternating arrangement"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:BlockCopolymer a owl:Class ;
    rdfs:label "BlockCopolymer"@en ;
    rdfs:subClassOf mds:Copolymer,
        mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A copolymer of two connected polymer types called blocks"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:GradientCopolymer a owl:Class ;
    rdfs:label "GradientCopolymer"@en ;
    rdfs:subClassOf mds:Copolymer,
        mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A copolymer of monomers with a gradual changing of monomer type ratio along the chain"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:GraftCopolymer a owl:Class ;
    rdfs:label "GraftCopolymer"@en ;
    rdfs:subClassOf mds:Copolymer,
        mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "A copolymer of a main backbone and one or more side chains of different polymers"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Tacticity a owl:Class ;
    rdfs:label "Tacticity"@en ;
    rdfs:subClassOf mds:PendantGroup ,
        mds:PolymerStructure ;
    skos:altLabel "" ;
    skos:definition "The spatial arrangement of pendant groups on a polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Isotactic a owl:Class ;
    rdfs:label "Isotactic"@en ;
    rdfs:subClassOf mds:Tacticity ;
    skos:altLabel "" ;
    skos:definition "Tacticity where all substituents are arranged on a single side of the backbone"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Syndiotactic a owl:Class ;
    rdfs:label "Syndiotactic"@en ;
    rdfs:subClassOf mds:Tacticity ;
    skos:altLabel "" ;
    skos:definition "Tacticity where the substituents are arranded in an alteranting ordered and patterned on the backbone"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Atactic a owl:Class ;
    rdfs:label "Atactic"@en ;
    rdfs:subClassOf mds:Tacticity ;
    skos:altLabel "" ;
    skos:definition "Tacticity where the substituents are arranged randomly on the backbone"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:PolymerCharacteristic a owl:Class ;
    rdfs:label "PolymerCharacteristic"@en ;
    rdfs:subClassOf obo:BFO0000019 ;
    skos:altLabel "" ;
    skos:definition "Polymer characteristic is a set of features that describe a polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation" ,
        "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:Thermoset a owl:Class ;
    rdfs:label "Thermoset"@en ;
