    skos:exactMatch cco:ont00000469 .

cco:ont00000570 a owl:Class ;
    rdfs:label "Force"@en ;
    rdfs:subClassOf obo:BFO_0000144 ;
    skos:definition "A Process Profile that is the rate of change of an object's Momentum, is the product of an object's Mass and Acceleration with respect to an inertial frame of reference, and is measured in units of Newtons (N)."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000653 a owl:Class ;
    rdfs:label "Algorithm"@en ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:definition "A Directive Information Content Entity that prescribes some Process and contains a finite sequence of unambiguous instructions in order to achieve some Objective."@en ;
    skos:exactMatch cco:ont00000653 ;
    mds:hasStudyStage "Analysis",
        "Modeling",
        "Recipe" ;
    cco:ont00001754 "http://purl.obolibrary.org/obo/IAO_0000064"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

cco:ont00000663 a owl:Class ;
    rdfs:label "Power Transmission Artifact"@en ;
