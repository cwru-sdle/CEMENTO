    rdfs:label "Alloy" ;
    rdfs:subClassOf mds:MetallicMaterial ;
    owl:disjointWith mds:PureMetal ;
    skos:altLabel " " ;
    skos:definition "A metallic material that is a mixture of chemical elements where the at least one of the element involved is a metal." ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Material-LPBF" .

mds:AmorphousPhase a owl:Class ;
    rdfs:label "AmorphousPhase" ;
    rdfs:subClassOf mds:Phase ;
    owl:disjointWith mds:CrystallinePhase ;
    skos:altLabel " " ;
    skos:definition "A Phase that exhibits order on length scales no longer than atomic length scale." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain " " .

mds:CeramicMaterial a owl:Class ;
    rdfs:label "CeramicMaterial" ;
    rdfs:subClassOf mds:Material ;
    owl:disjointWith mds:CompositeMaterial,
        mds:MetallicMaterial,
        mds:PolymericMaterial ;
    skos:altLabel " " ;
    skos:definition "A material in which all constituent phases are inorganic and nonmetallic, such that none are polymeric or metallic in structure or bonding. The dominant bonding is ionic, covalent, or a combination thereof." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain " " .

mds:CrystallinePhase a owl:Class ;
    rdfs:label "CrystallinePhase" ;
    rdfs:subClassOf obo:BFO_0000001 ;
    owl:equivalentClass [ owl:intersectionOf ( mds:Phase
                                                [ rdf:type owl:Restriction ;
                                                owl:onProperty [ owl:inverseOf mds:hasPhase
                                                                ] ;
                                                owl:someValuesFrom mds:Crystal
                                                ]
                                            ) ;
                        rdf:type owl:Class
                        ] ;
    skos:altLabel " " ;
    skos:definition "A Phase that exhibits long-range order, with repeatable units of atomic arrangement extending across large length scale." ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain " " .

mds:hasReinforcement a owl:ObjectProperty ;
    rdfs:label "has reinforcement" ;
    rdfs:subPropertyOf mds:hasPart,
        mds:hasStructuralQuality .

cco:ont00000228 a owl:Class ;
    rdfs:label "Planned Act"@en ;
    rdfs:subClassOf cco:ont00000005 ;
    skos:altLabel "Intentional Act"@en ;
    skos:definition "An Act in which at least one Agent plays a causative role and which is prescribed by some Directive Information Content Entity held by at least one of the Agents."@en ;
    mds:hasStudyStage "Recipe" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000457 a owl:Class ;
    rdfs:label "Portion of Material"@en ;
    rdfs:subClassOf cco:ont00001084 ;
    skos:definition "A Portion of Processed Material that was produced to be used as the input for another Act of Artifact Processing."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

obo:BFO_0000029 a owl:Class ;
    rdfs:label "site"@en ;
    dc:identifier "034-BFO" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( obo:BFO_0000029 obo:BFO_0000040 ) ] ;
            owl:onProperty obo:BFO_0000176 ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( obo:BFO_0000029 obo:BFO_0000140 ) ] ;
            owl:onProperty obo:BFO_0000178 ],
        [ a owl:Restriction ;
            owl:allValuesFrom obo:BFO_0000028 ;
            owl:onProperty obo:BFO_0000210 ],
        obo:BFO_0000141 ;
    skos:definition "(Elucidation) A site is a three-dimensional immaterial entity whose boundaries either (partially or wholly) coincide with the boundaries of one or more material entities or have locations determined in relation to some material entity"@en ;
    skos:example "A hole in a portion of cheese; a rabbit hole; the Grand Canyon; the Piazza San Marco; the kangaroo-joey-containing hole of a kangaroo pouch; your left nostril (a fiat part - the opening - of your left nasal cavity); the lumen of your gut; the hold of a ship; the interior of the trunk of your car; hole in an engineered floor joist"@en .

