mds:CeramicMatrixComposite a owl:Class ;
    rdfs:label "CeramicMatrixComposite" ;
    rdfs:subClassOf mds:CompositeMaterial ;
    owl:disjointWith mds:MetalMatrixComposite,
        mds:PolymerMatrixComposite ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( mds:CompositeMaterial [ a owl:Class ;
                        owl:unionOf ( [ a owl:Restriction ;
                                    owl:onProperty mds:hasReinforcement ;
                                    owl:someValuesFrom mds:MetallicMaterial ] [ a owl:Restriction ;
                                    owl:onProperty mds:hasReinforcement ;
                                    owl:someValuesFrom mds:PolymericMaterial ] ) ] [ a owl:Restriction ;
                        owl:onProperty mds:hasMatrix ;
                        owl:someValuesFrom mds:CeramicMaterial ] ) ] ;
    skos:altLabel " " ;
    skos:definition " " ;
    mds:hasDomain " " ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain " " .

