    rdfs:label "Compound"@en ;
    rdfs:subClassOf obo:CHEBI_24431 ;
    skos:altLabel "" ;
    skos:definition "A compound is a substance formed by the chemical bonding of two or more elements. [IUPAC]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Formulation",
        "Sample" ;
    mds:hasSubDomain "Chem-Rxn"@en ,
        "Chem-Form"@en .

mds:CompoundName a owl:Class ;
    rdfs:label "CompoundName"@en ;
    rdfs:subClassOf cco:ont00000003 ;
