@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################### Ontology Information ###########################
mds:Ontology a owl:Ontology ;
    rdfs:label "MDS-Onto" ;
    dcterms:creator "SDLE Research Center" ;
    dcterms:description "MDS-Onto is a domain (low) level ontology that describes terms in Materials Data Science. It is divided into six large modules: BuiltEnv, Exposure, Chemistry, Manufacture, Characterization, and Geospatial. Under each module, there are multiple sub-modules such as FTIR, AFM, Chem-Rxn, PV-Module, Accelerated Exposure, etc. " ;
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
    dcterms:title "MDS-Onto" ;
    owl:versionInfo "0.3.1.17" .


################## MDS Annotation Properties ########################

mds:hasDomain a owl:AnnotationProperty .

mds:hasSubDomain a owl:AnnotationProperty .

mds:hasStudyStage a owl:AnnotationProperty .


