    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Result" ;
    mds:hasSubDomain "Chem-Rxn"@en ,
        "Chem-Form"@en ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/International_Chemical_Identifier"@en .

