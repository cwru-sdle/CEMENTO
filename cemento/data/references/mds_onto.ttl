cco:ObjectAggreagte a owl:Class .

obo:BFO_0000019 a owl:Class .

cco:ont00000031 a owl:Class ;
    rdfs:label "Atmospheric Feature"@en ;
    rdfs:subClassOf cco:ont00001081 ;
    skos:definition "A Geographic Feature that is part of the atmosphere (including the atmosphere itself as a non-proper part) having a relatively stable lifecycle and which has a location that can be distinguished from the surrounding portion of the atmosphere."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasSubDomain "Chem-Rxn"@en .

cco:ont00000110 a owl:Class ;
    rdfs:label "Mechanical Process"@en ;
    skos:exactMatch cco:ont00000110 ;
    mds:hasStudyStage "Materials Processing" .

cco:ont00000117 a owl:Class ;
    rdfs:label "Information Processing Artifact"@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to use algorithms to transform some Information Content Entity into another Information Content Entity."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000119 a owl:Class ;
    rdfs:label "Spatial Orientation"@en ;
    rdfs:subClassOf obo:BFO_0000145 ;
    skos:altLabel "Attitude"@en ;
    skos:definition "A Relational Quality that is the angle of Rotation of an Object relative to one or more Plane of Reference or Axis of Rotation."@en ;
    mds:hasDomain "Charact" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Orientation_(geometry)" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000136 a owl:Class ;
    rdfs:label "Optical Instrument"@en ;
    rdfs:comment "Optical Instruments are typically constructed for the purpose of being used to aid in vision or the analysis of light" ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to process light waves"@en ;
    skos:scopeNote "Light waves can be processed in a variety of ways including via reflection, refraction, diffraction, deflection, focusing, collimation, dispersion, and interference."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Opt-UvVis" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Optical_instrument&oldid=1061981216"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000236 a owl:Class ;
    rdfs:label "Lighting System"@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to emit light within some area."@en ;
    mds:hasStudyStage "Materials Processing",
        "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000251 a owl:Class ;
    rdfs:label "Continent"@en ;
    skos:exactMatch cco:ont00000251 .

cco:ont00000288 a owl:Class ;
    rdfs:label "Power Source"@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to supply power to some other Artifact."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Power_source&oldid=1032888635"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000313 a owl:Class ;
    rdfs:label "Wavelength"@en ;
    rdfs:comment "Assuming a non-dispersive media, the Wavelength will be the inverse of the Frequency."@en ;
    rdfs:subClassOf cco:ont00000752 ;
    skos:definition "A Wave Process Profile that is the distance the Wave Process traverses during one Wave Cycle."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-Profil",
        "Material-XRD",
        "Opt-FTIR",
        "Opt-UvVis" ;
    mds:unit qudt:ANGSTROM ;
    mds:value xsd:float ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000324 a owl:Class ;
    rdfs:label "Width"@en ;
    rdfs:subClassOf cco:ont00001367 ;
    skos:broader mds:Recipe ;
    skos:definition "A One Dimensional Extent that inheres in a bearer in virtue of the bearer's extension in a horizontal direction."@en ;
    skos:exactMatch cco:ont00000324 ;
    mds:hasDomain "BuiltEnv",
        "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Material-XRD",
        "Opt-FTIR",
        "PV-Module" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000338 a owl:Class ;
    rdfs:label "Fan"@en ;
    rdfs:subClassOf cco:ont00000256 ;
    skos:definition "A Fluid Control Artifact that consists of a rotating arrangement of vanes or blades that are designed to act on a portion of fluid to create flow within it."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Fan_(machine)" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000345 a owl:Class ;
    rdfs:label "Act of Measuring"@en ;
    rdfs:subClassOf cco:ont00000228 ;
    skos:definition "A Planned Act that involves determining the extent, dimensions, quanity, or quality of an Entity relative to some standard."@en ;
    skos:example "putting an object on a scale to measure its weight in kilograms",
        "rating Hollywood movies on a 1 to 5 star scale",
        "using a tape measure to determine the height and width of a doorway in inches" ;
    mds:hasStudyStage "Analysis",
        "Synthesis" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000443 a owl:Class ;
    rdfs:label "Commercial Organization"@en ;
    rdfs:subClassOf cco:ont00001180 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( cco:ont00001180 [ a owl:Restriction ;
                        owl:onProperty obo:BFO_0000196 ;
                        owl:someValuesFrom cco:ont00000485 ] ) ] ;
    skos:definition "An Organization that is the bearer of a Commercial Role and whose primary objective is to make a profit from the provision of goods or services."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/AgentOntology"^^xsd:anyURI .

cco:ont00000544 a owl:Class ;
    rdfs:label "Target"@en ;
    rdfs:comment "Although people speak of targeting a process, say, a parade, what in fact are being targeted are the material participants of that process. The disruption or ceasing of the process is the objective of some plan, but not technically a target. Only material things can be targeted for action. Even if some dependent entity is described as being the target, the material thing for which that dependent entity depends is the object of a targeting process."@en ;
    rdfs:subClassOf obo:BFO_0000040 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( obo:BFO_0000040 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001936 ;
                        owl:someValuesFrom cco:ont00000741 ] ) ] ;
    skos:definition "A Material Entity that is the object of an Act of Targeting."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000564 a owl:Class ;
    rdfs:label "Educational Organization"@en ;
    rdfs:subClassOf cco:ont00001180 ;
    skos:definition "An Organization whose primary purpose is to provide training or otherwise facilitate learning or the acquisition of knowledge, Skills, values, beliefs, or habits."@en ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Education&oldid=1064011752"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/AgentOntology"^^xsd:anyURI .

cco:ont00000569 a owl:Class ;
    rdfs:label "Sensor"@en ;
    rdfs:subClassOf cco:ont00000736 ;
    skos:definition "A Transducer that is designed to convert incoming energy into a output signal which reliably corresponds to changes in that energy."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Sensor&oldid=1059883466"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000592 a owl:Class ;
    rdfs:label "Veracity Measurement Information Content Entity"@en ;
    rdfs:comment "'Deviation Measurement Information Content Entity' and 'Veracity Measurement Information Content Entity' are complementary notions. Deviation is a measure of whether reality conforms to an ICE (e.g., a plan or prediction), whereas Veracity is a measure of whether a Descriptive ICE conforms to reality."@en,
        "Note, the term 'accuracy' is avoided due to its ambiguity between: correctness-of-performance (see: 'Reliability Measurement Information Content Entity'), correctness-of-information ('Veracity Measurement Information Content Entity'), and adherance-to-expectations (see: 'Deviation Measurement Information Content Entity')."@en ;
    rdfs:subClassOf cco:ont00001163 ;
    skos:altLabel "Accuracy of Information"@en,
        "Trueness Measurement"@en,
        "Veracity Measurement"@en ;
    skos:definition "A Measurement Information Content Entity that is a measurement of the extent to which a description conforms to the reality it describes."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

cco:ont00000604 a owl:Class ;
    rdfs:label "Maximum Ordinal Measurement Information Content Entity"@en ;
    skos:exactMatch cco:ont00000604 ;
    mds:hasStudyStage "Result" .

cco:ont00000607 a owl:Class ;
    rdfs:label "Thickness"@en ;
    rdfs:subClassOf cco:ont00000892 ;
    skos:definition "A Depth that inheres in a bearer in virtue of it extending inward through an object."@en ;
    skos:exactMatch cco:ont00000607 ;
    mds:hasDomain "BuiltEnv",
        "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Opt-FTIR",
        "PV-Module" ;
    cco:ont00001754 "International Organization for Standardization. 2019. Quantities and units -- Part 3: Space and time (ISO 80000-3:2019). International Organization for Standardization. Available at: https://www.iso.org/standard/64974.html."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000752 a owl:Class ;
    rdfs:label "Wave Process Profile"@en ;
    rdfs:comment "This is a defined class used to group process profiles of Wave Processes. Note that not every relevant process profile can be asserted as a subtype, however, because they (e.g. Frequency and Amplitude) are applicable to other processes as well (e.g. Oscillation Process)."@en ;
    rdfs:subClassOf obo:BFO_0000144 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( obo:BFO_0000144 [ a owl:Restriction ;
                        owl:onProperty cco:ont00001857 ;
                        owl:someValuesFrom cco:ont00000099 ] ) ] ;
    skos:definition "A Process Profile of a Wave Process."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000763 a owl:Class ;
    rdfs:label "Velocity"@en ;
    rdfs:subClassOf obo:BFO_0000144 ;
    skos:definition "A Process Profile of an object's Motion that is characterized by its Speed and direction with respect to a frame of reference."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Velocity&oldid=1063300750"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00000771 a owl:Class ;
    rdfs:label "Imaging Instrument"@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to produce images (visual representations) of an entity."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000781 a owl:Class ;
    rdfs:label "Control System"@en ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A Material Artifact that is designed to manage, command, direct, or regulate the behavior of at least one other Artifact."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Control_system&oldid=1061817176"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00000784 a owl:Class ;
    rdfs:label "Optical Property"@en ;
    rdfs:subClassOf cco:ont00000628 ;
    skos:definition "An Electromagnetic Radiation Property that is realized when its bearer interacts with electromagnetic waves within the visible light spectrum."@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Opt-UvVis" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000845 a owl:Class ;
    rdfs:label "Proportional Ratio Measurement Information Content Entity"@en ;
    rdfs:comment "A percentage is one way to express a proportional measure where the decimal expression of the proportion is multiplied by 100, thus giving the proportional value with respect to a whole of 100. E.g., the ratio of pigs to cows on a farm is 44 to 79 (44:79 or 44/79). The proportion of pigs to total animals is 44 to 123 or 44/123. The percentage of pigs is the decimal equivalent of the proportion (0.36) multiplied by a 100 (36%). The percentage can be expressed as a proportion where the numerator value is transformed for a denominator of 100, i.e., 36 of a 100 animals are pigs (36/100)."@en,
        "We may want to add either a subclass for Percentage or a data property (has percentage value) that links the percentage expression for a proportion to the relevant IBE."@en ;
    rdfs:subClassOf cco:ont00001022 ;
    skos:definition "A Ratio Measurement Information Content Entity that is a measurement of a portion of a whole (described by the numerator) compared against that whole (described by the denominator) where the whole is a nominally described set of like entities."@en ;
    mds:hasStudyStage "Result" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

cco:ont00000892 a owl:Class ;
    rdfs:label "Depth"@en ;
    rdfs:subClassOf cco:ont00001367 ;
    skos:definition "A One Dimensional Extent that inheres in a bearer in virtue of the bearer's extension in a downward, backward, or inward direction."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "International Organization for Standardization. 2019. Quantities and units -- Part 3: Space and time (ISO 80000-3:2019). International Organization for Standardization. Available at: https://www.iso.org/standard/64974.html."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000932 a owl:Class ;
    rdfs:label "Computing Artifact Function"@en ;
    skos:exactMatch cco:ont00000932 ;
    mds:hasStudyStage "Tool" .

cco:ont00000967 a owl:Class ;
    rdfs:label "Height"@en ;
    rdfs:subClassOf cco:ont00001367 ;
    skos:definition "A One Dimensional Extent that inheres in a bearer in virtue of the bearer's extension in a vertical direction."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "International Organization for Standardization. 2019. Quantities and units -- Part 3: Space and time (ISO 80000-3:2019). International Organization for Standardization. Available at: https://www.iso.org/standard/64974.html."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00000970 a owl:Class ;
    rdfs:label "Act of Artifact Modification"@en ;
    rdfs:comment "Excluded from this class are instances of role change or role creation such as the introduction of an artifact as a piece of evidence in a trial or the loading of artifacts onto a ship for transport."@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:definition "An Act of Artifact Processing in which an existing Artifact is acted upon in a manner that changes, adds, or removes one or more of its Qualities, Dispositions, or Functions."@en ;
    mds:hasStudyStage "Materials Processing" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001065 a owl:Class ;
    rdfs:label "Two Dimensional Extent"@en ;
    rdfs:subClassOf cco:ont00001202 ;
    skos:altLabel "Area"@en ;
    skos:definition "A Size Quality that inheres in a bearer in virtue of the bearer's extension in two dimensions."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "International Organization for Standardization. 2019. Quantities and units -- Part 3: Space and time (ISO 80000-3:2019). International Organization for Standardization. Available at: https://www.iso.org/standard/64974.html."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/QualityOntology"^^xsd:anyURI .

cco:ont00001100 a owl:Class ;
    rdfs:label "Measurement Artifact Function"@en ;
    rdfs:subClassOf cco:ont00000323 ;
    skos:definition "An Artifact Function that is realized during events in which an Artifact is used to measure one or more features of a specified object or class of objects."@en ;
    mds:hasStudyStage "Tool" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ArtifactOntology"^^xsd:anyURI .

cco:ont00001149 a owl:Class ;
    rdfs:label "Data Range Interval Estimate Information Content Entity"@en ;
    skos:exactMatch cco:ont00001149 ;
    mds:hasStudyStage "Recipe" .

cco:ont00001309 a owl:Class ;
    rdfs:label "Lot Number"@en ;
    rdfs:subClassOf cco:ont00000077 ;
    skos:definition "A Code Identifier that designates a particular quantity or lot of material from a single manufacturer."@en ;
    mds:hasStudyStage "Sample" ;
    cco:ont00001754 "https://en.wikipedia.org/w/index.php?title=Lot_number&oldid=1061846325"^^xsd:anyURI ;
    cco:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

cco:ont00001359 a owl:Class ;
    rdfs:label "Act of Manufacturing"@en ;
    rdfs:comment "An Act of Manufacturing typically involves the mass production of goods."@en ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:definition "An Act of Artifact Processing wherein Artifacts are created in a Facility for the purpose of being sold to consumers."@en ;
    mds:hasStudyStage "Materials Processing" ;
    cco:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

cco:ont00001778 a owl:Class ;
    rdfs:label "has object"@en ;
    skos:exactMatch cco:ont00001778 .

cco:ont00001787 a owl:ObjectProperty ;
    rdfs:label "agent in"@en .

cco:ont00001801 a owl:ObjectProperty ;
    rdfs:label "is subject of"@en .

cco:ont00001803 a owl:ObjectProperty ;
    rdfs:label "is cause of"@en ;
    rdfs:domain obo:BFO_0000003 ;
    rdfs:range obo:BFO_0000003 ;
    owl:inverseOf cco:ont00001819 ;
    skos:definition "x is_cause_of y iff x and y are instances of Occurrent, and y is a consequence of x."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001833 a owl:ObjectProperty ;
    rdfs:label "has agent"@en ;
    owl:inverseOf cco:ont00001787 ;
    skos:exactMatch cco:ont00001833 .

cco:ont00001834 a owl:ObjectProperty ;
    rdfs:label "affects"@en ;
    rdfs:domain obo:BFO_0000015 ;
    rdfs:range obo:BFO_0000002 ;
    rdfs:subPropertyOf obo:BFO_0000057 ;
    owl:inverseOf cco:ont00001886 ;
    skos:definition "x affects y iff x is an instance of Process and y is an instance of Continuant, and x influences y in some manner, most often by producing a change in y."@en ;
    skos:exactMatch cco:ont00001834 ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001836 a owl:ObjectProperty ;
    rdfs:label "aggregate bearer of"@en ;
    skos:exactMatch cco:ont00001836 .

cco:ont00001841 a owl:ObjectProperty ;
    rdfs:label "is input of"@en ;
    rdfs:domain obo:BFO_0000002 ;
    rdfs:range obo:BFO_0000015 ;
    rdfs:subPropertyOf obo:BFO_0000056 ;
    owl:inverseOf cco:ont00001921 ;
    skos:definition "x is_input_of y iff x is an instance of Continuant and y is an instance of Process, such that the presence of x at the beginning of y is a necessary condition for the start of y."@en ;
    skos:exactMatch cco:ont00001841 ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001861 a owl:ObjectProperty ;
    rdfs:label "is material of"@en ;
    rdfs:domain obo:BFO_0000030 ;
    rdfs:range obo:BFO_0000030 ;
    owl:inverseOf cco:ont00001991 ;
    skos:definition "x is_material_of y when both x and y are instances of Object and y consists of x as its material and x undergoes no change of kind during the creation of y."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001863 a owl:ObjectProperty ;
    rdfs:label "uses measurement unit"@en ;
    skos:exactMatch cco:ont00001863 .

cco:ont00001874 a owl:ObjectProperty ;
    rdfs:label "is temporal region of"@en ;
    rdfs:domain obo:BFO_0000008 ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( obo:BFO_0000015 obo:BFO_0000035 ) ] ;
    skos:definition "t is temporal region of p iff p occupies temporal region t."@en ;
    skos:editorialNote "Leaving this is in ERO for now since BFO2020 has no inverse of occupies-temporal-region yet."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001879 a owl:ObjectProperty ;
    rdfs:label "designated by"@en ;
    owl:inverseOf cco:ont00001916 ;
    skos:exactMatch cco:ont00001879 .

cco:ont00001884 a owl:ObjectProperty ;
    rdfs:label "condition described by"@en .

cco:ont00001908 a owl:ObjectProperty ;
    rdfs:label "uses time zone identifier"@en ;
    skos:exactMatch cco:ont00001908 .

cco:ont00001913 a owl:ObjectProperty ;
    rdfs:label "uses geospatial coordinate reference system"@en ;
    skos:exactMatch cco:ont00001913 .

cco:ont00001918 a owl:ObjectProperty ;
    rdfs:label "occurs at"@en ;
    rdfs:domain obo:BFO_0000015 ;
    rdfs:range obo:BFO_0000029 ;
    rdfs:subPropertyOf obo:BFO_0000066 ;
    skos:definition "x occurs_at y iff x is an instance of Process and y is an instance of Site, such that x occurs in y."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

cco:ont00001920 a owl:ObjectProperty ;
    rdfs:label "prescribed by"@en .

cco:ont00001953 a owl:ObjectProperty ;
    rdfs:label "has parent"@en ;
    skos:exactMatch cco:ont00001953 .

cco:ont00001964 a owl:ObjectProperty ;
    rdfs:label "is measured by interval"@en ;
    skos:exactMatch cco:ont00001964 .

cco:ont00001991 a owl:ObjectProperty ;
    rdfs:label "is made of"@en ;
    rdfs:domain obo:BFO_0000030 ;
    rdfs:range obo:BFO_0000030 ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf cco:ont00001861 ;
    skos:definition "x is_made_of y when x and y are both instances of Object and y is the material that x consists of and that material does not undergo a change of kind during the creation of x."@en ;
    cco:ont00001760 "https://www.commoncoreontologies.org/ExtendedRelationOntology"^^xsd:anyURI .

afe:AFR_0001856 a owl:Class ;
    rdfs:label "electric current"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    mds:hasDomain "Chem"@en ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:BFO_0000024 a owl:Class ;
    rdfs:label "fiat object part"@en ;
    rdfs:subClassOf obo:BFO_0000030 ;
    skos:exactMatch obo:BFO_0000024 ;
    mds:hasDomain "Charact" ;
    mds:hasSubDomain "Material-LPBF" .

obo:BFO_0000055 a owl:ObjectProperty ;
    rdfs:label "realizes"@en ;
    skos:exactMatch obo:BFO_0000055 .

obo:BFO_0000129 a owl:ObjectProperty ;
    rdfs:label "member part of"@en ;
    skos:exactMatch obo:BFO_0000129 .

obo:BFO_0000171 a owl:ObjectProperty ;
    rdfs:label "located in"@en ;
    skos:exactMatch obo:BFO_0000171 .

obo:BFO_0000183 a owl:ObjectProperty ;
    rdfs:label "environs"@en ;
    skos:exactMatch obo:BFO_0000183 .

obo:BFO_0000210 a owl:ObjectProperty ;
    rdfs:label "occupies spatial region"@en ;
    skos:exactMatch obo:BFO_0000210 .

obo:CHMO_0000613 a owl:Class ;
    rdfs:label "pulsed nuclear magnetic resonance spectroscopy"@en ;
    rdfs:subClassOf obo:CHMO_0000591 ;
    skos:altLabel "NMR"@en ;
    skos:definition "Spectroscopy where the energy states of spin-active nuclei placed in a static magnetic field are interrogated by inducing transitions between the states via radio frequency irradiation. Each experiment consists of a sequence of radio frequency pulses with delay periods in between them. this is what is usually meant nowadays by NMR. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0001549 a owl:Class ;
    rdfs:label "sample drying"@en ;
    rdfs:subClassOf obo:OBI_0000094 ;
    skos:definition "The processing of removing a solvent from a substance. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Materials Processing" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002351 a owl:Class ;
    rdfs:label "electrochemical cell"@en ;
    rdfs:subClassOf obo:OBI_0000968 ;
    skos:definition "A piece of apparatus in which a current causes chemical reactions or chemical reactions cause a current to flow. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Tool" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002389 a owl:Class ;
    rdfs:label "total ion chromatogram"@en ;
    rdfs:subClassOf obo:CHMO_0002388 ;
    skos:altLabel "TIC"@en ;
    skos:definition "A plot of the total ion current vs. retention time obtained from a chromatography experiment with mass detection. selectivity in the data. The total ion current chromatogram monitors a very large window often of several hundred mass-to-charge units.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002774 a owl:Class ;
    rdfs:label "stirring"@en ;
    rdfs:subClassOf obo:CHMO_0001685 ;
    skos:definition "Stirring process is a mixing process that involves the agitation of a solution through circular motion. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:OBI_0000070 a owl:Class ;
    rdfs:label "assay"@en ;
    rdfs:subClassOf obo:OBI_0000011 ;
    skos:definition "A planned process that has the objective to produce information about a material entity (the evaluant) by examining it.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis",
        "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

mds:ActOfCharacterizing a owl:Class ;
    rdfs:label "ActOfCharacterizing"@en ;
    rdfs:subClassOf cco:ont00000345 ;
