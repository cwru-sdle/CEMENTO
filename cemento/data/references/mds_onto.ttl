    skos:scopeNote "This property is a measured result for an uncured polymer"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:HeatAgingProperty a owl:Class ;
