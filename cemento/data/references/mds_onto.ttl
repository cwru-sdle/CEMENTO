    rdfs:comment "This term is reused from Allotrope Foundation Material Ontology"@en ;
    rdfs:isDefinedBy "<http://purl.allotrope.org/ontologies/material#>" ;
    rdfs:subClassOf cco:ont00000503 ;
    skos:exactMatch afm:AFM_0000884 ;
