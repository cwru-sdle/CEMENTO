obo:CHMO_0002856 a owl:Class ;
    rdfs:label "enantiomer excess"@en ;
    rdfs:subClassOf obo:BFO_0000145 ;
    skos:altLabel "EE"@en ;
    skos:definition "The absolute value of the mole fraction for one enantiomer in a mixture minus the mole fraction for the other enantiomer. most people quote percentage enantiomer excess, CHMO:0002857. [CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en .

obo:CHMO_0002858 a owl:Class ;
    rdfs:label "diasteromeric ratio"@en ;
    rdfs:subClassOf obo:BFO_0000145 ;
    skos:altLabel "DR"@en ;
    skos:definition "The ratio of the percentage of one diastereomer in a mixture to that of the other.[CHMO]"@en,
        "This is defined by analogy with enantiomeric ratio as the ratio of the percentage of one diastereoisomer in a mixture to that of the other [IUPAC]. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://doi.org/10.1351/goldbook.D01681"@en .

obo:CHMO_0002859 a owl:Class ;
    rdfs:label "enantiomeric ratio"@en ;
    rdfs:subClassOf obo:BFO_0000145 ;
    skos:altLabel "ER"@en ;
    skos:definition "The ratio of the percentage of one enantiomer in a mixture to that of the other e.g.70(+):30(-). [IUPAC]"@en,
        "The ratio of the percentage of one enantiomer in a mixture to that of the other.[CHMO]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en ;
    cco:ont00001754 "https://doi.org/10.1351/goldbook.E02075"@en .

