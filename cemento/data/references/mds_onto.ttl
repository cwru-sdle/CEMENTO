    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Result" ;
    mds:hasSubDomain "Chem-Rxn"@en ,
        "Chem-Form"@en ;
    cco:ont00001754 "https://doi.org/10.1186/s13321-018-0277-8"@en .


mds:ReactionPressure a owl:Class ;
    rdfs:label "ReactionPressure"@en ;
    rdfs:subClassOf cco:ont00000380 ;
    skos:altLabel "" ;
    skos:definition "A reaction pressure is the pressure during a chemical reaction process inside the reaction glassware inheres by the reaction environment."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ,
        "Chem-Form"@en ;
    mds:hasSubDomain "Chem-Rxn"@en .

mds:ReactionProcedure a owl:Class ;
    rdfs:label "ReactionProcedure"@en ;
    rdfs:subClassOf cco:ont00000127 ;
    skos:altLabel "" ;
    skos:definition "A Performance Specification (directive ICE) that prescribes how a chemical reaction process should be carried out to be successful"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ,
        "Chem-Form"@en ;
    mds:hasSubDomain "Chem-Rxn"@en .

mds:ReactionTemperature a owl:Class ;
    rdfs:label "ReactionTemperature"@en ;
    rdfs:subClassOf cco:ont00000441 ;
    qudt:applicableUnit unit:DEG_C ,
        unit:K , unit:DEG_F ;
    skos:altLabel "" ;
    skos:definition "A reaction temperature is a temperature measured by a device during a reaction. It is not the temperature setpoint (which might be prescribed in the procedure and the chemical equation)"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ,
        "Chem-Form"@en ;
    mds:hasSubDomain "Chem-Rxn"@en .

mds:ReactionTime a owl:Class ;
    rdfs:label "ReactionTime"@en ;
    rdfs:subClassOf obo:BFO_0000202 ;
    qudt:applicableUnit unit:HR ,
        unit:DAY , unit:MIN ;
    skos:altLabel "" ;
    skos:definition "A reaction time is a temporal interval of a chemical reaction process that is a one-dimensional temporal region that is continuous, thus without gaps or breaks. The period of time that elapses between the start of the reaction and the attainment of a given extent of a reaction. [IUPAC]"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Synthesis" ;
    mds:hasSubDomain "Chem-Rxn"@en ,
        "Chem-Form"@en ;
    cco:ont00001754 "https://doi.org/10.1351/goldbook.R05179"@en .

mds:TemperatureSetpoint a owl:Class ;
    rdfs:label "TemperatureSetpoint"@en ;
    qudt:applicableUnit unit:DEG_C ,
        unit:K , unit:DEG_F ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:altLabel "" ;
    skos:definition "A temperature setpoint is an information content entity about the designated temperature of a reaction that is set in a device that controls the temperature"@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Chem-Rxn"@en ,
        "Chem-Form"@en .

cco:ont00000768 a owl:Class ;
    rdfs:label "Amount"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A Quality that inheres in a bearer in virtue of the total, aggregate or sum of a number of discrete items or material the entity contains as parts."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasSubDomain "Chem-Rxn"@en ,
        "Chem-Form"@en .


#### MONONMER/MACROMER LEVEL


mds:MolecularWeight a owl:Class ;
    rdfs:label "MolecularWeight"@en ;
    rdfs:subClassOf mds:Measurement ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition ""@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:NumberAverageMolecularWeight a owl:Class ;
    rdfs:label "NumberAverageMolecularWeight"@en ;
    rdfs:subClassOf mds:MolecularWeight ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Calculated by dividing the sum of the molecular weights of all molecules by the total number of molecules. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:WeightAverageMolecularWeight a owl:Class ;
    rdfs:label "WeightAverageMolecularWeight"@en ;
    rdfs:subClassOf mds:MolecularWeight ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "Calculated by summing the weighted molecular weights of each molecule; it gives more importance to heavier molecules. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:ZAverageMolecularWeight a owl:Class ;
    rdfs:label "ZAverageMolecularWeight"@en ;
    rdfs:subClassOf mds:MolecularWeight ,
        mds:AnalyticalResult ;
    skos:altLabel "" ;
    skos:definition "A higher-order average that gives even more importance to the largest molecules in the sample. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:EntanglementWeight a owl:Class ;
    rdfs:label "EntanglementWeight"@en ;
    rdfs:subClassOf mds:MolecularWeight ;
    skos:altLabel "" ;
    skos:definition "Average molecular weight between entanglement points. "@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Chem-Form"@en .

mds:meetsTargetSpecification a owl:DatatypeProperty ;
    skos:altLabel "meets target specification"@en ;
    rdfs:range xsd:boolean ;
    rdfs:label "meetsTargetSpecification"@en.

mds:NumberOfUnits a owl:DatatypeProperty ;
