mds:ExposureOrder a owl:Class ;
    rdfs:label "ExposureOrder"@en ;
    rdfs:comment """Contact:
Martin Jäcklein
Fraunhofer Institute for High-Speed Dynamics , Ernst-Mach-Institut, EMI
Ernst-Zermelo-Strasse 4, 79104 Freiburg , Germany
Martin.Huschka@EMI.Fraunhofer.de"""@en,
        "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO"@en,
        "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "Order of exposure by the laser in an additive manufacturing process."@en ;
    skos:exactMatch lpbfo:LPBFO_00031 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

mds:ExposureOrderFile a owl:Class ;
    rdfs:label "ExposureOrderFile"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "A file that contains the knowledge about the additive manufacturing process to be performed. It includes process information and parameters, such as admissible grain fraction, ranges for the beam diameter, laser power, layer thickness and scanning speed depending on the material and the different areas (contour, up-, down-skin, reduced quenching volume). This information might be stored as a process diagram."@en ;
    skos:exactMatch lpbfo:LPBFO_00708 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

mds:ExposureOrderOnScanVectors a owl:Class ;
    rdfs:label "ExposureOrderOnScanVectors"@en ;
    rdfs:comment "This term is reused from https://gitlab.cc-asp.fraunhofer.de/EMI_datamanagement/LPBFO/-/blob/master/LPBFO_merged.ttl."@en ;
    rdfs:subClassOf obo:BFO_0000001 ;
    skos:altLabel " " ;
    skos:definition "This process describes the application of the stored exposure strategy, which also contains rules for up- and down-skin areas and contours, to the scan vectors. For each scan vector, the affiliation to the different areas is determined beforehand so that the rules can be applied. Output of this process is the CNCExposureOrderFile."@en ;
    skos:exactMatch lpbfo:LPBFO_00706 ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Recipe" ;
    mds:hasSubDomain "Material-LPBF" .

