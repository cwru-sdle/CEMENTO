mds:AnalyticalResult a owl:Class ;
    rdfs:label "AnalyticalResult"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:altLabel " " ;
    skos:definition "An analytical result is an information content entity that is about the outcome of an analysis process. The analysis process can be a characterization method (UV-VIS or NMR) or a data analysis method such as calculating the mean/average."@en ;
    skos:example "In the chemical reaction context, an analytical result is an information content entity that is about a product (output) of a chemical reaction process determined by a measuring process such as percentage yield calculated via the mass measured."@en ;
    mds:hasDomain "Chem"@en ;
    mds:hasStudyStage "Analysis",
        "Result" ;
    mds:hasSubDomain "Chem-Rxn"@en .

