    rdfs:label "PortionOfTiAlloy" ;
    rdfs:subClassOf mds:Alloy ;
    skos:altLabel "Portion of Titanium Alloy",
        "Ti" ;
    skos:definition "Metal alloy of nickel and titanium, where the two elements are present in roughly equal atomic percentages [Wiki]"@en ;
    mds:hasDomain "Charact" ;
    mds:hasStudyStage "Sample" ;
    mds:hasSubDomain "Material-LPBF" ;
    cco:ont00001754 "https://en.wikipedia.org/wiki/Nickel_titanium"@en .

mds:PortionOfToolSteel a owl:Class ;
    rdfs:label "PortionOfToolSteel" ;
